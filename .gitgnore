# Generated by Cargo
/target
**/target

# Cargo.lock is intentionally NOT ignored — Iris builds a binary (server),
# and binaries should commit their lockfile for reproducible builds.
# (If any crate here is ever published as a standalone library, ignore
# that crate's own Cargo.lock instead.)

# Editor / IDE
.idea/
.vscode/
*.swp
*.swo
*~

# OS
.DS_Store
Thumbs.db

# Local config, secrets, env files — never commit real credentials/keys
.env
.env.local
*.pem
*.key
config/local.toml

# Logs
*.log

# Backup / temp files
*.bak
*.tmp

# Test / coverage output
/coverage
*.profraw
