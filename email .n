// ============================================================================
// CONSTANTS
// ============================================================================

/** Default IMAP port (143) */
const val IMAP_PORT = 143

/** Default IMAPS port (993) */
const val IMAPS_PORT = 993

/** Maximum line length per RFC 2683 (8KB) */
const val MAX_LINE_LENGTH = 8192

/** Maximum literal size to accept (25MB) */
const val MAX_LITERAL_SIZE = 25L * 1024 * 1024

/** Connection timeout (30 seconds) */
const val CONNECTION_TIMEOUT_MS = 30_000L

/** Read timeout (60 seconds) */
const val READ_TIMEOUT_MS = 60_000L

/** Write timeout (30 seconds) */
const val WRITE_TIMEOUT_MS = 30_000L

/** Maximum retry attempts */
const val MAX_RETRIES = 3

/** Base retry delay (1 second) */
const val RETRY_DELAY_MS = 1_000L

/** Maximum retry delay (30 seconds) */
const val MAX_RETRY_DELAY_MS = 30_000L

/** IDLE timeout - 29 minutes (RFC 2177) */
const val IDLE_TIMEOUT_MS = 29L * 60 * 1000

/** Keep-alive interval (5 minutes) */
const val KEEP_ALIVE_MS = 5L * 60 * 1000

/** Maximum pipelined commands */
const val MAX_PIPELINE = 10

/** Connection pool size */
const val POOL_SIZE = 3

/** Pool max idle time (5 minutes) */
const val POOL_MAX_IDLE_MS = 5L * 60 * 1000

/** Client identity string */
const val CLIENT_ID = "SuperEmail-Android/3.2.1"

// ============================================================================
// ENUMS
// ============================================================================

/** IMAP connection states per RFC 3501 Section 3 */
enum class ImapState(val desc: String) {
    NOT_AUTHENTICATED("Initial state, authentication required"),
    AUTHENTICATED("Authenticated, mailbox operations available"),
    SELECTED("Mailbox selected, message operations available"),
    LOGOUT("Connection termination in progress")
}

/** IMAP command types with their requirements */
enum class ImapCommand(
    val cmd: String,
    val minState: ImapState,
    val needsSelected: Boolean = false
) {
    // Any state
    CAPABILITY("CAPABILITY", ImapState.NOT_AUTHENTICATED),
    NOOP("NOOP", ImapState.NOT_AUTHENTICATED),
    LOGOUT("LOGOUT", ImapState.NOT_AUTHENTICATED),
    
    // Not authenticated
    STARTTLS("STARTTLS", ImapState.NOT_AUTHENTICATED),
    AUTHENTICATE("AUTHENTICATE", ImapState.NOT_AUTHENTICATED),
    LOGIN("LOGIN", ImapState.NOT_AUTHENTICATED),
    
    // Authenticated
    SELECT("SELECT", ImapState.AUTHENTICATED),
    EXAMINE("EXAMINE", ImapState.AUTHENTICATED),
    CREATE("CREATE", ImapState.AUTHENTICATED),
    DELETE("DELETE", ImapState.AUTHENTICATED),
    RENAME("RENAME", ImapState.AUTHENTICATED),
    SUBSCRIBE("SUBSCRIBE", ImapState.AUTHENTICATED),
    UNSUBSCRIBE("UNSUBSCRIBE", ImapState.AUTHENTICATED),
    LIST("LIST", ImapState.AUTHENTICATED),
    LSUB("LSUB", ImapState.AUTHENTICATED),
    STATUS("STATUS", ImapState.AUTHENTICATED),
    APPEND("APPEND", ImapState.AUTHENTICATED),
    
    // Selected
    CHECK("CHECK", ImapState.SELECTED, true),
    CLOSE("CLOSE", ImapState.SELECTED, true),
    EXPUNGE("EXPUNGE", ImapState.SELECTED, true),
    SEARCH("SEARCH", ImapState.SELECTED, true),
    FETCH("FETCH", ImapState.SELECTED, true),
    STORE("STORE", ImapState.SELECTED, true),
    COPY("COPY", ImapState.SELECTED, true),
    UID("UID", ImapState.SELECTED, true),
    
    // Extensions
    IDLE("IDLE", ImapState.SELECTED, true),
    NAMESPACE("NAMESPACE", ImapState.AUTHENTICATED),
    ENABLE("ENABLE", ImapState.AUTHENTICATED),
    COMPRESS("COMPRESS", ImapState.AUTHENTICATED),
    SORT("SORT", ImapState.SELECTED, true),
    THREAD("THREAD", ImapState.SELECTED, true),
    ID("ID", ImapState.NOT_AUTHENTICATED),
    MOVE("MOVE", ImapState.SELECTED, true),
    UNSELECT("UNSELECT", ImapState.SELECTED, true)
}

/** Server response types */
enum class ImapResponseType {
    OK,       // Success
    NO,       // Failure
    BAD,      // Protocol error
    PREAUTH,  // Pre-authenticated
    BYE,      // Goodbye
    CONTINUATION  // +
}

/** Fetchable message attributes */
enum class FetchAttribute(val attr: String) {
    UID("UID"),
    FLAGS("FLAGS"),
    INTERNALDATE("INTERNALDATE"),
    RFC822_SIZE("RFC822.SIZE"),
    ENVELOPE("ENVELOPE"),
    BODY("BODY[]"),
    BODY_PEEK("BODY.PEEK[]"),
    BODYSTRUCTURE("BODYSTRUCTURE"),
    MODSEQ("MODSEQ"),
    PREVIEW("PREVIEW")
}

/** Search criteria keys per RFC 3501 Section 6.4.4 */
enum class SearchKey {
    ALL, ANSWERED, BCC, BEFORE, BODY, CC, DELETED, DRAFT,
    FLAGGED, FROM, HEADER, KEYWORD, LARGER, NEW, NOT, OLD,
    ON, OR, RECENT, SEEN, SENTBEFORE, SENTON, SENTSINCE,
    SINCE, SMALLER, SUBJECT, TEXT, TO, UID, UNANSWERED,
    UNDELETED, UNDRAFT, UNFLAGGED, UNKEYWORD, UNSEEN,
    YOUNGER, OLDER
}

/** Sort criteria for SORT extension */
enum class SortCriterion(val crit: String) {
    ARRIVAL("ARRIVAL"), CC("CC"), DATE("DATE"),
    FROM("FROM"), SIZE("SIZE"), SUBJECT("SUBJECT"), TO("TO")
}

/** Email flags */
enum class MailFlag(val imapFlag: String) {
    SEEN("\\Seen"),
    ANSWERED("\\Answered"),
    FLAGGED("\\Flagged"),
    DELETED("\\Deleted"),
    DRAFT("\\Draft"),
    RECENT("\\Recent"),
    FORWARDED("\$Forwarded"),
    JUNK("\$Junk"),
    NOT_JUNK("\$NotJunk"),
    IMPORTANT("\$Important"),
    PHISHING("\$Phishing")
}

/** Store operation types */
enum class StoreOp(val op: String) {
    SET_FLAGS("FLAGS"),
    ADD_FLAGS("+FLAGS"),
    REMOVE_FLAGS("-FLAGS"),
    SET_SILENT("FLAGS.SILENT"),
    ADD_SILENT("+FLAGS.SILENT"),
    REMOVE_SILENT("-FLAGS.SILENT")
}

/** Thread algorithms for THREAD extension */
enum class ThreadAlgorithm(val algo: String) {
    ORDEREDSUBJECT("ORDEREDSUBJECT"),
    REFERENCES("REFERENCES"),
    REFS("REFS")
}

/** Authentication mechanisms */
enum class AuthMethod {
    PLAIN, LOGIN, CRAM_MD5, SCRAM_SHA1, SCRAM_SHA256,
    XOAUTH2, OAUTHBEARER, NTLM, GSSAPI
}

/** Connection event types */
enum class ConnectionEvent {
    CONNECTED, DISCONNECTED, AUTHENTICATED, MAILBOX_SELECTED,
    MAILBOX_CLOSED, IDLE_STARTED, IDLE_STOPPED, ERROR
}

// ============================================================================
// DATA CLASSES
// ============================================================================

/** IMAP server configuration */
data class ImapConfig(
    val host: String,
    val port: Int = IMAPS_PORT,
    val useSsl: Boolean = true,
    val connectionTimeout: Long = CONNECTION_TIMEOUT_MS,
    val readTimeout: Long = READ_TIMEOUT_MS,
    val writeTimeout: Long = WRITE_TIMEOUT_MS,
    val maxRetries: Int = MAX_RETRIES,
    val retryDelay: Long = RETRY_DELAY_MS,
    val enableCompression: Boolean = true,
    val enableIdle: Boolean = true,
    val certPins: List<String> = emptyList(),
    val allowedCipherSuites: List<String> = emptyList(),
    val debugMode: Boolean = false
)

/** Mailbox information */
data class MailboxInfo(
    val name: String,
    val attributes: List<String> = emptyList(),
    val delimiter: String = "/",
    val exists: Int = 0,
    val recent: Int = 0,
    val unseen: Int = 0,
    val uidNext: Long = 0,
    val uidValidity: Long = 0,
    val highestModSeq: Long = 0,
    val appendLimit: Long? = null
)

/** Email address */
data class EmailAddress(
    val name: String? = null,
    val mailbox: String? = null,
    val host: String? = null
) {
    val email: String get() = if (mailbox != null && host != null) "$mailbox@$host" else ""
}

/** Email envelope */
data class EmailEnvelope(
    val date: String? = null,
    val subject: String? = null,
    val from: List<EmailAddress>? = null,
    val sender: List<EmailAddress>? = null,
    val replyTo: List<EmailAddress>? = null,
    val to: List<EmailAddress>? = null,
    val cc: List<EmailAddress>? = null,
    val bcc: List<EmailAddress>? = null,
    val inReplyTo: String? = null,
    val messageId: String? = null
)

/** MIME body structure */
data class BodyStructure(
    val type: String,
    val subtype: String,
    val params: Map<String, String> = emptyMap(),
    val id: String? = null,
    val description: String? = null,
    val encoding: String? = null,
    val size: Long = 0,
    val lines: Int? = null,
    val md5: String? = null,
    val disposition: String? = null,
    val dispositionParams: Map<String, String> = emptyMap(),
    val language: String? = null,
    val location: String? = null,
    val parts: List<BodyStructure>? = null
)

/** Fetch response for a message */
data class FetchResponse(
    val seqNum: Long,
    val uid: Long? = null,
    val flags: Set<MailFlag>? = null,
    val internalDate: Date? = null,
    val size: Long? = null,
    val envelope: EmailEnvelope? = null,
    val bodyStructure: BodyStructure? = null,
    val body: ByteArray? = null,
    val modSeq: Long? = null,
    val preview: String? = null
)

/** IMAP protocol response */
data class ImapResponse(
    val tag: String? = null,
    val type: ImapResponseType,
    val message: String = "",
    val responseCode: String? = null,
    val responseData: Map<String, String> = emptyMap()
)

/** Server capabilities */
data class ImapCapability(
    val imap4rev1: Boolean = false,
    val imap4rev2: Boolean = false,
    val auth: Set<AuthMethod> = emptySet(),
    val startTls: Boolean = false,
    val idle: Boolean = false,
    val namespace: Boolean = false,
    val uidPlus: Boolean = false,
    val condStore: Boolean = false,
    val qResync: Boolean = false,
    val enable: Boolean = false,
    val compress: Boolean = false,
    val sort: Boolean = false,
    val thread: Set<ThreadAlgorithm> = emptySet(),
    val move: Boolean = false,
    val unselect: Boolean = false,
    val children: Boolean = false,
    val multiAppend: Boolean = false,
    val esearch: Boolean = false,
    val searchRes: Boolean = false,
    val within: Boolean = false,
    val listExtended: Boolean = false,
    val listStatus: Boolean = false,
    val specialUse: Boolean = false,
    val metadata: Boolean = false,
    val notify: Boolean = false,
    val saslIR: Boolean = false,
    val appendLimit: Long? = null,
    val rights: Boolean = false,
    val objectId: Boolean = false,
    val replace: Boolean = false,
    val saveDate: Boolean = false,
    val preview: Boolean = false,
    val literalPlus: Boolean = false,
    val literalMinus: Boolean = false,
    val rawCapabilities: Map<String, String> = emptyMap()
)

/** Namespace information */
data class Namespace(
    val personal: List<NamespaceEntry> = emptyList(),
    val otherUsers: List<NamespaceEntry> = emptyList(),
    val shared: List<NamespaceEntry> = emptyList()
)

data class NamespaceEntry(
    val prefix: String,
    val delimiter: String
)

/** Search criteria */
data class SearchCriteria(
    val keys: List<SearchKey>,
    val values: List<String> = emptyList(),
    val charset: String? = null,
    val uidRange: String? = null
)

/** Connection metrics for monitoring */
data class ConnectionMetrics(
    val totalConnections: Long = 0,
    val activeConnections: Int = 0,
    val totalCommands: Long = 0,
    val failedCommands: Long = 0,
    val bytesSent: Long = 0,
    val bytesReceived: Long = 0,
    val avgResponseTime: Double = 0.0,
    val lastActivityTime: Long = 0
)

// ============================================================================
// EXCEPTION HIERARCHY
// ============================================================================

/** Base exception for all IMAP errors */
open class ImapException(
    message: String,
    cause: Throwable? = null
) : Exception(message, cause)

/** Connection-related errors */
class ImapConnectionException(
    message: String,
    cause: Throwable? = null
) : ImapException(message, cause)

/** Authentication failures */
class ImapAuthException(
    message: String,
    val authMethod: AuthMethod? = null
) : ImapException(message)

/** Protocol command errors */
class ImapCommandException(
    val responseType: ImapResponseType,
    message: String,
    val serverResponse: String? = null
) : ImapException(message)

/** Parsing errors for server responses */
class ImapParseException(
    message: String,
    val rawResponse: String? = null
) : ImapException(message)

/** Timeout errors */
class ImapTimeoutException(
    message: String,
    val operation: String? = null
) : ImapException(message)

/** State machine violations */
class ImapStateException(
    message: String,
    val currentState: ImapState? = null,
    val expectedState: ImapState? = null
) : ImapException(message)

/** SSL/TLS errors */
class ImapSSLException(
    message: String,
    cause: Throwable? = null
) : ImapException(message, cause)

/** Mailbox-specific errors */
class ImapMailboxException(
    message: String,
    val mailboxName: String? = null
) : ImapException(message)

/** Resource limit exceeded */
class ImapLimitException(
    message: String,
    val limit: Long? = null
) : ImapException(message)

// ============================================================================
// LOGGER
// ============================================================================

/**
 * Simple structured logger for IMAP operations.
 * Supports debug levels and log retention.
 */
class ImapLogger(
    private val maxEntries: Int = 10_000,
    private val debugEnabled: Boolean = false
) {
    enum class Level { DEBUG, INFO, WARN, ERROR }
    
    data class Entry(
        val timestamp: Long = System.currentTimeMillis(),
        val level: Level,
        val message: String,
        val throwable: Throwable? = null,
        val threadName: String = Thread.currentThread().name
    )
    
    private val entries = ConcurrentLinkedQueue<Entry>()
    
    fun debug(msg: String) = log(Level.DEBUG, msg)
    fun info(msg: String) = log(Level.INFO, msg)
    fun warn(msg: String, t: Throwable? = null) = log(Level.WARN, msg, t)
    fun error(msg: String, t: Throwable? = null) = log(Level.ERROR, msg, t)
    
    private fun log(level: Level, msg: String, t: Throwable? = null) {
        if (level == Level.DEBUG && !debugEnabled) return
        val entry = Entry(level = level, message = msg, throwable = t)
        entries.add(entry)
        while (entries.size > maxEntries) entries.poll()
    }
    
    fun getRecent(n: Int = 100): List<Entry> = entries.takeLast(n)
    fun clear() = entries.clear()
}

// ============================================================================
// CONNECTION POOL
// ============================================================================

/**
 * Thread-safe connection pool for IMAP connections.
 * Manages multiple connections to improve concurrency.
 */
class ImapConnectionPool(
    private val config: ImapConfig,
    private val logger: ImapLogger,
    private val maxSize: Int = POOL_SIZE,
    private val maxIdleMs: Long = POOL_MAX_IDLE_MS
) {
    private data class PooledConnection(
        val handler: ImapProtocolHandler,
        val createdAt: Long = System.currentTimeMillis(),
        var lastUsed: Long = System.currentTimeMillis(),
        var inUse: Boolean = false
    )
    
    private val pool = CopyOnWriteArrayList<PooledConnection>()
    private val lock = Mutex()
    
    /**
     * Acquires a connection from the pool or creates a new one.
     * Automatically authenticates if credentials are cached.
     */
    suspend fun acquire(): ImapProtocolHandler = lock.withLock {
        // Find idle connection
        val idle = pool.find { !it.inUse && isHealthy(it) }
        if (idle != null) {
            idle.inUse = true
            idle.lastUsed = System.currentTimeMillis()
            logger.debug("Reusing pooled connection")
            return idle.handler
        }
        
        // Clean expired connections
        cleanup()
        
        // Create new if under limit
        if (pool.size < maxSize) {
            val handler = ImapProtocolHandler(config, logger)
            val pc = PooledConnection(handler, inUse = true)
            pool.add(pc)
            logger.debug("Created new connection (pool: ${pool.size})")
            return handler
        }
        
        // Wait for available connection
        throw ImapLimitException("Connection pool exhausted (max: $maxSize)")
    }
    
    /**
     * Returns a connection to the pool.
     */
    suspend fun release(handler: ImapProtocolHandler) = lock.withLock {
        pool.find { it.handler === handler }?.let {
            it.inUse = false
            it.lastUsed = System.currentTimeMillis()
            logger.debug("Released connection to pool")
        }
    }
    
    /**
     * Removes a connection from the pool.
     */
    suspend fun remove(handler: ImapProtocolHandler) = lock.withLock {
        pool.removeAll { it.handler === handler }
        logger.debug("Removed connection from pool (remaining: ${pool.size})")
    }
    
    /**
     * Closes all connections in the pool.
     */
    suspend fun closeAll() = lock.withLock {
        pool.forEach { pc ->
            try {
                pc.handler.disconnect()
            } catch (e: Exception) {
                logger.warn("Error closing pooled connection", e)
            }
        }
        pool.clear()
    }
    
    private fun isHealthy(pc: PooledConnection): Boolean {
        val idleTime = System.currentTimeMillis() - pc.lastUsed
        return idleTime < maxIdleMs && pc.handler.isConnected()
    }
    
    private fun cleanup() {
        pool.removeAll { pc ->
            !pc.inUse && (System.currentTimeMillis() - pc.lastUsed > maxIdleMs)
        }
    }
    
    fun size(): Int = pool.size
    fun activeCount(): Int = pool.count { it.inUse }
}

// ============================================================================
// METRICS COLLECTOR
// ============================================================================

/**
 * Collects and reports connection metrics for monitoring.
 */
class ImapMetrics {
    private val totalConnections = AtomicLong(0)
    private val activeConnections = AtomicInteger(0)
    private val totalCommands = AtomicLong(0)
    private val failedCommands = AtomicLong(0)
    private val bytesSent = AtomicLong(0)
    private val bytesReceived = AtomicLong(0)
    private val responseTimes = ConcurrentLinkedQueue<Long>()
    private val lastActivity = AtomicLong(0)
    
    fun recordConnection() {
        totalConnections.incrementAndGet()
        activeConnections.incrementAndGet()
    }
    
    fun recordDisconnection() {
        activeConnections.decrementAndGet()
    }
    
    fun recordCommand() = totalCommands.incrementAndGet()
    fun recordFailedCommand() = failedCommands.incrementAndGet()
    fun recordBytesSent(bytes: Long) = bytesSent.addAndGet(bytes)
    fun recordBytesReceived(bytes: Long) = bytesReceived.addAndGet(bytes)
    
    fun recordResponseTime(ms: Long) {
        responseTimes.add(ms)
        while (responseTimes.size > 1000) responseTimes.poll()
    }
    
    fun recordActivity() {
        lastActivity.set(System.currentTimeMillis())
    }
    
    fun getMetrics(): ConnectionMetrics = ConnectionMetrics(
        totalConnections = totalConnections.get(),
        activeConnections = activeConnections.get(),
        totalCommands = totalCommands.get(),
        failedCommands = failedCommands.get(),
        bytesSent = bytesSent.get(),
        bytesReceived = bytesReceived.get(),
        avgResponseTime = responseTimes.average(),
        lastActivityTime = lastActivity.get()
    )
    
    fun reset() {
        totalConnections.set(0)
        activeConnections.set(0)
        totalCommands.set(0)
        failedCommands.set(0)
        bytesSent.set(0)
        bytesReceived.set(0)
        responseTimes.clear()
        lastActivity.set(0)
    }
}

// ============================================================================
// MAIN PROTOCOL HANDLER (START - ~6000 lines remaining)
// ============================================================================

/**
 * Core IMAP protocol handler implementing RFC 3501 and extensions.
 * 
 * This class manages a single IMAP connection including:
 * - Connection lifecycle (connect, disconnect, reconnect)
 * - Authentication (password, OAuth2, SASL)
 * - Mailbox operations (select, create, delete, rename)
 * - Message operations (fetch, search, store, copy, move)
 * - Real-time updates via IDLE
 * - State machine enforcement
 * - Error handling and retry logic
 * 
 * @param config IMAP server configuration
 * @param logger Structured logger for debugging
 */
class ImapProtocolHandler(
    private val config: ImapConfig,
    private val logger: ImapLogger = ImapLogger(debugEnabled = config.debugMode)
) {
    // ========================================================================
    // STATE MANAGEMENT
    // ========================================================================
    
    /** Current connection state */
    private val state = AtomicReference(ImapState.NOT_AUTHENTICATED)
    
    /** Currently selected mailbox */
    private val selectedMailbox = AtomicReference<MailboxInfo?>(null)
    
    /** Server capabilities cache */
    private val capabilities = AtomicReference(ImapCapability())
    
    /** Tag counter for command identification */
    private val tagCounter = AtomicLong(0)
    
    /** Whether connection is established */
    private val connected = AtomicBoolean(false)
    
    /** Authentication state */
    private val authenticated = AtomicBoolean(false)
    
    /** Cached credentials for reconnection */
    private var cachedCredentials: Pair<String, String>? = null
    private var cachedOAuthToken: Pair<String, String>? = null
    
    // ========================================================================
    // CONNECTION RESOURCES
    // ========================================================================
    
    private var socket: Socket? = null
    private var sslSocket: SSLSocket? = null
    private var reader: BufferedReader? = null
    private var writer: BufferedWriter? = null
    private var rawInput: InputStream? = null
    private var rawOutput: OutputStream? = null
    private var compressedInput: InflaterInputStream? = null
    private var compressedOutput: DeflaterOutputStream? = null
    
    // ========================================================================
    // CONCURRENCY CONTROL
    // ========================================================================
    
    private val commandLock = Mutex()
    private val writeLock = Mutex()
    private val idleLock = Mutex()
    private val connectionMutex = Mutex()
    private val responseChannel = Channel<ImapResponse>(Channel.BUFFERED)
    
    // ========================================================================
    // IDLE MANAGEMENT
    // ========================================================================
    
    private var idleJob: Job? = null
    private val idleCallbacks = CopyOnWriteArrayList<IdleCallback>()
    private val eventCallbacks = CopyOnWriteArrayList<ConnectionEventCallback>()
    
    // ========================================================================
    // METRICS
    // ========================================================================
    
    private val metrics = ImapMetrics()
    
    // ========================================================================
    // RESPONSE PARSER
    // ========================================================================
    
    private val responseParser = ImapResponseParser()
    
    // ========================================================================
    // CONNECTION MANAGEMENT (~1500 lines)
    // ========================================================================
    
    /**
     * Establishes connection to IMAP server with full handshake.
     * 
     * Sequence:
     * 1. TCP socket connection
     * 2. SSL/TLS handshake (if using SSL port)
     * 3. Read server greeting
     * 4. Get initial capabilities
     * 5. Optional STARTTLS upgrade
     * 6. Optional ID command
     * 7. Optional COMPRESS negotiation
     * 
     * @return Result indicating success or failure
     */
    suspend fun connect(): Result<Unit> = connectionMutex.withLock {
        if (connected.get()) {
            logger.warn("Already connected, disconnecting first")
            disconnectInternal()
        }
        
        try {
            logger.info("Connecting to ${config.host}:${config.port}")
            
            // Create socket with timeout
            socket = Socket().apply {
                connect(
                    InetSocketAddress(config.host, config.port),
                    config.connectionTimeout.toInt()
                )
                soTimeout = config.readTimeout.toInt()
                tcpNoDelay = true
                keepAlive = true
            }
            
            // Setup SSL if using SSL port
            if (config.useSsl) {
                upgradeToSSL()
            }
            
            // Setup I/O streams
            setupStreams()
            
            // Read server greeting
            val greeting = readResponseInternal()
            if (greeting.type == ImapResponseType.BYE) {
                throw ImapConnectionException("Server rejected: ${greeting.message}")
            }
            
            // Initialize state
            connected.set(true)
            state.set(ImapState.NOT_AUTHENTICATED)
            authenticated.set(false)
            selectedMailbox.set(null)
            
            // Get initial capabilities
            fetchCapabilities()
            
            // Send client ID
            sendIdCommand()
            
            metrics.recordConnection()
            notifyEvent(ConnectionEvent.CONNECTED)
            
            logger.info("Connected to ${config.host} successfully")
            Result.success(Unit)
            
        } catch (e: Exception) {
            logger.error("Connection failed", e)
            disconnectInternal()
            Result.failure(ImapConnectionException("Connection failed: ${e.message}", e))
        }
    }
    
    /**
     * Upgrades existing plain connection to SSL/TLS via STARTTLS.
     */
    private suspend fun upgradeToSSL() {
        val sslContext = SSLContext.getInstance("TLSv1.3")
        val trustManager = createTrustManager()
        sslContext.init(null, arrayOf(trustManager), SecureRandom())
        
        sslSocket = sslContext.socketFactory.createSocket(
            socket,
            config.host,
            config.port,
            true
        ) as SSLSocket
        
        sslSocket!!.apply {
            enabledProtocols = arrayOf("TLSv1.3", "TLSv1.2")
            if (config.allowedCipherSuites.isNotEmpty()) {
                enabledCipherSuites = config.allowedCipherSuites.toTypedArray()
            }
            startHandshake()
            logger.debug("SSL handshake completed: ${session.cipherSuite}")
        }
    }
    
    /**
     * Creates X509TrustManager with optional certificate pinning.
     */
    private fun createTrustManager(): X509TrustManager {
        if (config.certPins.isNotEmpty()) {
            return PinningTrustManager(config.certPins)
        }
        return DefaultTrustManager()
    }
    
    /**
     * Certificate pinning trust manager for enhanced security.
     */
    private class PinningTrustManager(
        private val pins: List<String>
    ) : X509TrustManager {
        override fun checkClientTrusted(chain: Array<X509Certificate>, authType: String) {}
        override fun getAcceptedIssuers(): Array<X509Certificate> = arrayOf()
        
        override fun checkServerTrusted(chain: Array<X509Certificate>, authType: String) {
            if (chain.isEmpty()) throw CertificateException("Empty certificate chain")
            val cert = chain[0]
            val digest = MessageDigest.getInstance("SHA-256")
                .digest(cert.publicKey.encoded)
            val pin = Base64.getEncoder().encodeToString(digest)
            if (pin !in pins) {
                throw CertificateException("Certificate pin mismatch: $pin")
            }
        }
    }
    
    /**
     * Default trust manager that validates against system trust store.
     */
    private class DefaultTrustManager : X509TrustManager {
        private val defaultTM: X509TrustManager
        
        init {
            val tmf = TrustManagerFactory.getInstance(TrustManagerFactory.getDefaultAlgorithm())
            tmf.init(null as KeyStore?)
            defaultTM = tmf.trustManagers.filterIsInstance<X509TrustManager>().first()
        }
        
        override fun checkClientTrusted(chain: Array<X509Certificate>, authType: String) =
            defaultTM.checkClientTrusted(chain, authType)
        override fun checkServerTrusted(chain: Array<X509Certificate>, authType: String) =
            defaultTM.checkServerTrusted(chain, authType)
        override fun getAcceptedIssuers() = defaultTM.acceptedIssuers
    }
    
    /**
     * Sets up buffered I/O streams with optional compression.
     */
    private fun setupStreams() {
        val activeSocket: Socket = sslSocket ?: socket!!
        val socketInput = activeSocket.getInputStream()
        val socketOutput = activeSocket.getOutputStream()
        
        if (config.enableCompression && capabilities.get().compress) {
            compressedInput = InflaterInputStream(socketInput)
            compressedOutput = DeflaterOutputStream(socketOutput, Deflater(Deflater.BEST_SPEED))
            rawInput = compressedInput
            rawOutput = compressedOutput
            logger.debug("Compression enabled")
        } else {
            rawInput = socketInput
            rawOutput = socketOutput
        }
        
        reader = BufferedReader(InputStreamReader(rawInput!!, Charsets.UTF_8), MAX_LINE_LENGTH)
        writer = BufferedWriter(OutputStreamWriter(rawOutput!!, Charsets.UTF_8))
    }
    
    /**
     * Disconnects gracefully with LOGOUT command.
     */
    suspend fun disconnect() {
        connectionMutex.withLock {
            try {
                if (connected.get() && state.get() != ImapState.LOGOUT) {
                    sendCommand("LOGOUT", skipLock = true)
                }
            } catch (e: Exception) {
                logger.debug("Logout failed: ${e.message}")
            } finally {
                disconnectInternal()
            }
        }
    }
    
    private fun disconnectInternal() {
        try { reader?.close() } catch (_: Exception) {}
        try { writer?.close() } catch (_: Exception) {}
        try { rawInput?.close() } catch (_: Exception) {}
        try { rawOutput?.close() } catch (_: Exception) {}
        try { compressedInput?.close() } catch (_: Exception) {}
        try { compressedOutput?.close() } catch (_: Exception) {}
        try { sslSocket?.close() } catch (_: Exception) {}
        try { socket?.close() } catch (_: Exception) {}
        
        reader = null; writer = null
        rawInput = null; rawOutput = null
        compressedInput = null; compressedOutput = null
        sslSocket = null; socket = null
        
        connected.set(false)
        authenticated.set(false)
        state.set(ImapState.LOGOUT)
        selectedMailbox.set(null)
        
        stopIdleJob()
        metrics.recordDisconnection()
        notifyEvent(ConnectionEvent.DISCONNECTED)
    }
    
    /**
     * Checks if connection is alive and healthy.
     */
    fun isConnected(): Boolean = connected.get() && socket?.isConnected == true
    
    /**
     * Checks if authenticated.
     */
    fun isAuthenticated(): Boolean = authenticated.get()
    
    /**
     * Gets current connection state.
     */
    fun getState(): ImapState = state.get()
    
    /**
     * Gets current server capabilities.
     */
    fun getCapabilities(): ImapCapability = capabilities.get()
    
    /**
     * Gets selected mailbox info.
     */
    fun getSelectedMailbox(): MailboxInfo? = selectedMailbox.get()
    
    /**
     * Gets connection metrics.
     */
    fun getMetrics(): ConnectionMetrics = metrics.getMetrics()
    
    // ========================================================================
    // NOTIFICATION SYSTEM
    // ========================================================================
    
    private fun notifyEvent(event: ConnectionEvent) {
        eventCallbacks.forEach { it.invoke(event) }
    }
    
    fun addEventListener(callback: ConnectionEventCallback) {
        eventCallbacks.add(callback)
    }
    
    fun removeEventListener(callback: ConnectionEventCallback) {
        eventCallbacks.remove(callback)
    }
    
    // ========================================================================
    // AUTHENTICATION (~800 lines)
    // ========================================================================
    
    /**
     * Authenticates using username and password.
     * Tries SASL mechanisms if available, falls back to LOGIN.
     */
    suspend fun login(username: String, password: String): Result<Unit> = 
        withContext(Dispatchers.IO) {
        try {
            if (state.get() != ImapState.NOT_AUTHENTICATED) {
                return@withContext Result.failure(
                    ImapStateException("Already authenticated", state.get())
                )
            }
            
            // Try STARTTLS if not using SSL
            if (!config.useSsl && capabilities.get().startTls) {
                startTls()
            }
            
            val caps = capabilities.get()
            val authMethod = selectBestAuthMethod(caps, password)
            
            val result = when (authMethod) {
                AuthMethod.SCRAM_SHA256 -> authScramSha256(username, password)
                AuthMethod.SCRAM_SHA1 -> authScramSha1(username, password)
                AuthMethod.CRAM_MD5 -> authCramMd5(username, password)
                AuthMethod.PLAIN -> authPlain(username, password)
                else -> authLogin(username, password)
            }
            
            if (result.isSuccess) {
                authenticated.set(true)
                state.set(ImapState.AUTHENTICATED)
                cachedCredentials = username to password
                fetchCapabilities()
                
                if (config.enableCompression && capabilities.get().compress) {
                    enableCompression()
                }
                
                notifyEvent(ConnectionEvent.AUTHENTICATED)
                logger.info("Authentication successful: $username")
            }
            
            result
            
        } catch (e: Exception) {
            logger.error("Authentication failed", e)
            Result.failure(ImapAuthException("Auth failed: ${e.message}"))
        }
    }
    
    /**
     * Authenticates using OAuth 2.0 token.
     */
    suspend fun loginOAuth2(
        username: String,
        accessToken: String
    ): Result<Unit> = withContext(Dispatchers.IO) {
        try {
            if (state.get() != ImapState.NOT_AUTHENTICATED) {
                return@withContext Result.failure(ImapStateException("Already authenticated"))
            }
            
            val caps = capabilities.get()
            val useXOAuth2 = caps.auth.contains(AuthMethod.XOAUTH2)
            val useOAuthBearer = caps.auth.contains(AuthMethod.OAUTHBEARER)
            
            when {
                useXOAuth2 -> authXOAuth2(username, accessToken)
                useOAuthBearer -> authOAuthBearer(username, accessToken)
                else -> return@withContext Result.failure(
                    ImapAuthException("Server doesn't support OAuth2")
                )
            }
            
            authenticated.set(true)
            state.set(ImapState.AUTHENTICATED)
            cachedOAuthToken = username to accessToken
            fetchCapabilities()
            notifyEvent(ConnectionEvent.AUTHENTICATED)
            
            Result.success(Unit)
            
        } catch (e: Exception) {
            Result.failure(ImapAuthException("OAuth2 failed: ${e.message}"))
        }
    }
    
    private fun selectBestAuthMethod(caps: ImapCapability, password: String): AuthMethod {
        return when {
            caps.auth.contains(AuthMethod.SCRAM_SHA256) -> AuthMethod.SCRAM_SHA256
            caps.auth.contains(AuthMethod.SCRAM_SHA1) -> AuthMethod.SCRAM_SHA1
            caps.auth.contains(AuthMethod.CRAM_MD5) -> AuthMethod.CRAM_MD5
            caps.auth.contains(AuthMethod.PLAIN) -> AuthMethod.PLAIN
            else -> AuthMethod.LOGIN
        }
    }
    
    private suspend fun authLogin(username: String, password: String): Result<Unit> {
        val encodedUser = Base64.getEncoder().encodeToString(username.toByteArray())
        val encodedPass = Base64.getEncoder().encodeToString(password.toByteArray())
        val response = executeCommand("LOGIN $encodedUser $encodedPass")
        
        return if (response.type == ImapResponseType.OK) {
            Result.success(Unit)
        } else {
            Result.failure(ImapAuthException("LOGIN failed: ${response.message}"))
        }
    }
    
    private suspend fun authPlain(username: String, password: String): Result<Unit> {
        val authString = "\u0000$username\u0000$password"
        val encoded = Base64.getEncoder().encodeToString(authString.toByteArray())
        val response = executeCommand("AUTHENTICATE PLAIN $encoded")
        
        return if (response.type == ImapResponseType.OK) {
            Result.success(Unit)
        } else {
            Result.failure(ImapAuthException("PLAIN auth failed: ${response.message}"))
        }
    }
    
    private suspend fun authCramMd5(username: String, password: String): Result<Unit> {
        val tag = nextTag()
        sendRaw("$tag AUTHENTICATE CRAM-MD5")
        
        // Get challenge
        val challenge = readResponseInternal()
        if (challenge.type != ImapResponseType.CONTINUATION) {
            return Result.failure(ImapAuthException("Expected challenge, got: ${challenge.type}"))
        }
        
        // Decode challenge
        val decoded = Base64.getDecoder().decode(challenge.message.trim())
        val challengeStr = String(decoded)
        
        // Compute HMAC-MD5 response
        val mac = Mac.getInstance("HmacMD5")
        mac.init(SecretKeySpec(password.toByteArray(), "HmacMD5"))
        val digest = mac.doFinal(challengeStr.toByteArray())
        val hexDigest = digest.joinToString("") { "%02x".format(it) }
        val response = "$username $hexDigest"
        val encoded = Base64.getEncoder().encodeToString(response.toByteArray())
        
        sendRaw(encoded)
        val finalResponse = readResponseInternal()
        
        return if (finalResponse.type == ImapResponseType.OK) {
            Result.success(Unit)
        } else {
            Result.failure(ImapAuthException("CRAM-MD5 failed: ${finalResponse.message}"))
        }
    }
    
    private suspend fun authScramSha1(username: String, password: String): Result<Unit> {
        return authScram(username, password, "SHA-1", "SCRAM-SHA-1")
    }
    
    private suspend fun authScramSha256(username: String, password: String): Result<Unit> {
        return authScram(username, password, "SHA-256", "SCRAM-SHA-256")
    }
    
    private suspend fun authScram(
        username: String,
        password: String,
        algorithm: String,
        mechanism: String
    ): Result<Unit> {
        val nonce = generateNonce()
        val clientFirstBare = "n=$username,r=$nonce"
        val gs2Header = "n,,"
        val clientFirst = gs2Header + clientFirstBare
        
        val tag = nextTag()
        sendRaw("$tag AUTHENTICATE $mechanism")
        sendRaw(Base64.getEncoder().encodeToString(clientFirst.toByteArray()))
        
        val challenge = readResponseInternal()
        if (challenge.type != ImapResponseType.CONTINUATION) {
            return Result.failure(ImapAuthException("Expected SCRAM continuation"))
        }
        
        val serverFirst = String(Base64.getDecoder().decode(challenge.message.trim()))
        val serverFirstParts = parseScramAttributes(serverFirst)
        val serverNonce = serverFirstParts["r"] ?: return Result.failure(
            ImapAuthException("Missing nonce in server response")
        )
        val salt = serverFirstParts["s"] ?: return Result.failure(
            ImapAuthException("Missing salt in server response")
        )
        val iterations = serverFirstParts["i"]?.toIntOrNull() ?: return Result.failure(
            ImapAuthException("Missing iterations in server response")
        )
        
        // Compute client final
        val saltedPassword = pbkdf2(password, Base64.getDecoder().decode(salt), iterations, algorithm)
        val clientKey = hmac(saltedPassword, "Client Key", algorithm)
        val storedKey = hash(clientKey, algorithm)
        val authMessage = "$clientFirstBare,${serverFirst.substringAfter(",")},c=biws,r=$serverNonce"
        val clientSignature = hmac(storedKey, authMessage, algorithm)
        val clientProof = xorBytes(clientKey, clientSignature)
        
        val clientFinal = "c=biws,r=$serverNonce,p=${Base64.getEncoder().encodeToString(clientProof)}"
        sendRaw(Base64.getEncoder().encodeToString(clientFinal.toByteArray()))
        
        val serverResponse = readResponseInternal()
        if (serverResponse.type != ImapResponseType.CONTINUATION) {
            return Result.failure(ImapAuthException("Expected SCRAM final continuation"))
        }
        
        val serverFinal = String(Base64.getDecoder().decode(serverResponse.message.trim()))
        val serverSignature = hmac(saltedPassword, "Server Key", algorithm)
        val expectedServerProof = hmac(serverSignature, authMessage, algorithm)
        val actualServerProof = Base64.getDecoder().decode(
            parseScramAttributes(serverFinal)["v"] ?: ""
        )
        
        if (!expectedServerProof.contentEquals(actualServerProof)) {
            return Result.failure(ImapAuthException("Server signature verification failed"))
        }
        
        sendRaw("") // Empty response
        val finalResp = readResponseInternal()
        
        return if (finalResp.type == ImapResponseType.OK) {
            Result.success(Unit)
        } else {
            Result.failure(ImapAuthException("SCRAM failed: ${finalResp.message}"))
        }
    }
    
    private suspend fun authXOAuth2(username: String, token: String): Result<Unit> {
        val authString = "user=$username\u0001auth=Bearer $token\u0001\u0001"
        val encoded = Base64.getEncoder().encodeToString(authString.toByteArray())
        val response = executeCommand("AUTHENTICATE XOAUTH2 $encoded")
        
        if (response.type == ImapResponseType.CONTINUATION) {
            sendRaw("")
            val finalResponse = readResponseInternal()
            return if (finalResponse.type == ImapResponseType.OK) {
                Result.success(Unit)
            } else {
                Result.failure(ImapAuthException("XOAUTH2 failed: ${finalResponse.message}"))
            }
        }
        
        return if (response.type == ImapResponseType.OK) {
            Result.success(Unit)
        } else {
            Result.failure(ImapAuthException("XOAUTH2 failed: ${response.message}"))
        }
    }
    
    private suspend fun authOAuthBearer(username: String, token: String): Result<Unit> {
        val authString = "n,a=$username,\u0001host=${config.host}\u0001port=${config.port}\u0001auth=Bearer $token\u0001\u0001"
        val encoded = Base64.getEncoder().encodeToString(authString.toByteArray())
        val response = executeCommand("AUTHENTICATE OAUTHBEARER $encoded")
        
        if (response.type == ImapResponseType.CONTINUATION) {
            sendRaw("")
            val finalResponse = readResponseInternal()
            return if (finalResponse.type == ImapResponseType.OK) {
                Result.success(Unit)
            } else {
                Result.failure(ImapAuthException("OAUTHBEARER failed: ${finalResponse.message}"))
            }
        }
        
        return if (response.type == ImapResponseType.OK) {
            Result.success(Unit)
        } else {
            Result.failure(ImapAuthException("OAUTHBEARER failed: ${response.message}"))
        }
    }
    
    private suspend fun startTls() {
        val response = executeCommand("STARTTLS")
        if (response.type == ImapResponseType.OK) {
            upgradeToSSL()
            setupStreams()
            logger.info("STARTTLS successful")
        } else {
            throw ImapCommandException(response.type, "STARTTLS failed: ${response.message}")
        }
    }
    
    private suspend fun enableCompression() {
        val response = executeCommand("COMPRESS DEFLATE")
        if (response.type == ImapResponseType.OK) {
            compressedInput = InflaterInputStream(rawInput!!)
            compressedOutput = DeflaterOutputStream(rawOutput!!, Deflater(Deflater.BEST_SPEED))
            reader = BufferedReader(InputStreamReader(compressedInput!!, Charsets.UTF_8))
            writer = BufferedWriter(OutputStreamWriter(compressedOutput!!, Charsets.UTF_8))
            logger.info("DEFLATE compression enabled")
        }
    }
    
    // ========================================================================
    // UTILITY METHODS FOR AUTH
    // ========================================================================
    
    private fun generateNonce(length: Int = 24): String {
        val random = SecureRandom()
        val bytes = ByteArray(length)
        random.nextBytes(bytes)
        return Base64.getEncoder().encodeToString(bytes).take(length)
    }
    
    private fun parseScramAttributes(data: String): Map<String, String> {
        val attrs = mutableMapOf<String, String>()
        data.split(",").forEach { pair ->
            val (key, value) = pair.split("=", limit = 2)
            attrs[key] = value
        }
        return attrs
    }
    
    private fun pbkdf2(
        password: String,
        salt: ByteArray,
        iterations: Int,
        algorithm: String
    ): ByteArray {
        val keySpec = PBEKeySpec(password.toCharArray(), salt, iterations, 256)
        val factory = SecretKeyFactory.getInstance("PBKDF2WithHmac$algorithm")
        return factory.generateSecret(keySpec).encoded
    }
    
    private fun hmac(key: ByteArray, data: String, algorithm: String): ByteArray {
        val mac = Mac.getInstance("Hmac$algorithm")
        mac.init(SecretKeySpec(key, "Hmac$algorithm"))
        return mac.doFinal(data.toByteArray())
    }
    
    private fun hash(data: ByteArray, algorithm: String): ByteArray {
        return MessageDigest.getInstance(algorithm).digest(data)
    }
    
    private fun xorBytes(a: ByteArray, b: ByteArray): ByteArray {
        val result = ByteArray(a.size)
        for (i in result.indices) {
            result[i] = (a[i].toInt() xor b[i].toInt()).toByte()
        }
        return result
    }
    
    // ========================================================================
    // MAILBOX OPERATIONS (~1000 lines)
    // ========================================================================
    
    /**
     * Selects a mailbox for read-write operations.
     * Parses and returns mailbox status information.
     */
    suspend fun selectMailbox(name: String): Result<MailboxInfo> = 
        withContext(Dispatchers.IO) {
        try {
            requireAuth()
            
            val tag = nextTag()
            sendRaw("$tag SELECT ${quoteString(name)}")
            
            val mailbox = parseSelectResponse(tag)
            selectedMailbox.set(mailbox)
            state.set(ImapState.SELECTED)
            notifyEvent(ConnectionEvent.MAILBOX_SELECTED)
            
            logger.info("Selected mailbox: $name (${mailbox.exists} msgs)")
            Result.success(mailbox)
            
        } catch (e: Exception) {
            Result.failure(e)
        }
    }
    
    /**
     * Selects a mailbox for read-only operations.
     */
    suspend fun examineMailbox(name: String): Result<MailboxInfo> = 
        withContext(Dispatchers.IO) {
        try {
            requireAuth()
            
            val tag = nextTag()
            sendRaw("$tag EXAMINE ${quoteString(name)}")
            
            val mailbox = parseSelectResponse(tag)
            selectedMailbox.set(mailbox)
            state.set(ImapState.SELECTED)
            
            Result.success(mailbox)
            
        } catch (e: Exception) {
            Result.failure(e)
        }
    }
    
    private suspend fun parseSelectResponse(tag: String): MailboxInfo {
        var flags = emptyList<String>()
        var exists = 0; var recent = 0; var unseen = 0
        var uidNext = 0L; var uidValidity = 0L
        var highestModSeq = 0L; var appendLimit: Long? = null
        
        while (true) {
            val line = reader!!.readLine() ?: throw ImapConnectionException("Connection closed")
            
            when {
                line.startsWith("* FLAGS (") -> {
                    val flagsStr = line.substringAfter("(").substringBefore(")")
                    flags = flagsStr.split(" ").filter { it.isNotEmpty() }
                }
                line.contains("EXISTS") -> exists = extractNumber(line)
                line.contains("RECENT") -> recent = extractNumber(line)
                line.contains("UNSEEN") -> {
                    Regex("UNSEEN (\\d+)").find(line)?.let {
                        unseen = it.groupValues[1].toInt()
                    }
                }
                line.contains("UIDNEXT") -> {
                    Regex("UIDNEXT (\\d+)").find(line)?.let {
                        uidNext = it.groupValues[1].toLong()
                    }
                }
                line.contains("UIDVALIDITY") -> {
                    Regex("UIDVALIDITY (\\d+)").find(line)?.let {
                        uidValidity = it.groupValues[1].toLong()
                    }
                }
                line.contains("HIGHESTMODSEQ") -> {
                    Regex("HIGHESTMODSEQ (\\d+)").find(line)?.let {
                        highestModSeq = it.groupValues[1].toLong()
                    }
                }
                line.contains("APPENDLIMIT") -> {
                    Regex("APPENDLIMIT (\\d+)").find(line)?.let {
                        appendLimit = it.groupValues[1].toLong()
                    }
                }
                line.startsWith("$tag OK") -> break
                line.startsWith("$tag NO") -> throw ImapMailboxException(
                    "SELECT failed: $line"
                )
                line.startsWith("$tag BAD") -> throw ImapCommandException(
                    ImapResponseType.BAD, "SELECT error: $line"
                )
            }
        }
        
        return MailboxInfo(
            name = selectedMailbox.get()?.name ?: "",
            attributes = flags,
            exists = exists,
            recent = recent,
            unseen = unseen,
            uidNext = uidNext,
            uidValidity = uidValidity,
            highestModSeq = highestModSeq,
            appendLimit = appendLimit
        )
    }
    
    /**
     * Lists mailboxes matching the given pattern.
     */
    suspend fun listMailboxes(
        reference: String = "",
        pattern: String = "*"
    ): Result<List<MailboxInfo>> = withContext(Dispatchers.IO) {
        try {
            requireAuth()
            
            val tag = nextTag()
            sendRaw("$tag LIST ${quoteString(reference)} ${quoteString(pattern)} RETURN (CHILDREN STATUS (MESSAGES UNSEEN))")
            
            val mailboxes = mutableListOf<MailboxInfo>()
            
            while (true) {
                val line = reader!!.readLine() ?: break
                if (line.startsWith("* LIST")) {
                    mailboxes.add(parseListResponse(line))
                } else if (line.startsWith("$tag OK")) {
                    break
                } else if (line.startsWith("$tag NO") || line.startsWith("$tag BAD")) {
                    throw ImapCommandException(
                        if (line.startsWith("$tag NO")) ImapResponseType.NO else ImapResponseType.BAD,
                        line
                    )
                }
            }
            
            Result.success(mailboxes)
            
        } catch (e: Exception) {
            Result.failure(e)
        }
    }
    
    private fun parseListResponse(line: String): MailboxInfo {
        // Parse: * LIST (attr1 attr2) "/" "MailboxName"
        val attrStart = line.indexOf('(')
        val attrEnd = line.indexOf(')')
        val attributes = if (attrStart >= 0 && attrEnd > attrStart) {
            line.substring(attrStart + 1, attrEnd).split(" ").filter { it.isNotEmpty() }
        } else emptyList()
        
        val afterAttrs = line.substring(attrEnd + 1).trim()
        val parts = parseQuotedStrings(afterAttrs)
        
        return MailboxInfo(
            name = parts.getOrElse(1) { "" },
            attributes = attributes,
            delimiter = parts.getOrElse(0) { "/" }
        )
    }
    
    /**
     * Creates a new mailbox.
     */
    suspend fun createMailbox(name: String): Result<Unit> = withContext(Dispatchers.IO) {
        try {
            requireAuth()
            val response = executeCommand("CREATE ${quoteString(name)}")
            if (response.type == ImapResponseType.OK) {
                Result.success(Unit)
            } else {
                Result.failure(ImapMailboxException("CREATE failed: ${response.message}", name))
            }
        } catch (e: Exception) {
            Result.failure(e)
        }
    }
    
    /**
     * Deletes a mailbox permanently.
     */
    suspend fun deleteMailbox(name: String): Result<Unit> = withContext(Dispatchers.IO) {
        try {
            requireAuth()
            val response = executeCommand("DELETE ${quoteString(name)}")
            if (response.type == ImapResponseType.OK) {
                Result.success(Unit)
            } else {
                Result.failure(ImapMailboxException("DELETE failed: ${response.message}", name))
            }
        } catch (e: Exception) {
            Result.failure(e)
        }
    }
    
    /**
     * Renames an existing mailbox.
     */
    suspend fun renameMailbox(oldName: String, newName: String): Result<Unit> = 
        withContext(Dispatchers.IO) {
        try {
            requireAuth()
            val response = executeCommand("RENAME ${quoteString(oldName)} ${quoteString(newName)}")
            if (response.type == ImapResponseType.OK) {
                Result.success(Unit)
            } else {
                Result.failure(ImapMailboxException("RENAME failed: ${response.message}", oldName))
            }
        } catch (e: Exception) {
            Result.failure(e)
        }
    }
    
    /**
     * Gets mailbox status without selecting it.
     */
    suspend fun getMailboxStatus(
        name: String,
        items: List<String> = listOf("MESSAGES", "RECENT", "UIDNEXT", "UIDVALIDITY", "UNSEEN")
    ): Result<MailboxInfo> = withContext(Dispatchers.IO) {
        try {
            requireAuth()
            
            val itemsStr = items.joinToString(" ") { it }
            val tag = nextTag()
            sendRaw("$tag STATUS ${quoteString(name)} ($itemsStr)")
            
            var mailbox = MailboxInfo(name = name)
            
            while (true) {
                val line = reader!!.readLine() ?: break
                if (line.startsWith("* STATUS")) {
                    mailbox = parseStatusResponse(line)
                } else if (line.startsWith("$tag OK")) {
                    break
                } else if (line.startsWith("$tag NO") || line.startsWith("$tag BAD")) {
                    throw ImapCommandException(
                        if (line.startsWith("$tag NO")) ImapResponseType.NO else ImapResponseType.BAD,
                        line
                    )
                }
            }
            
            Result.success(mailbox)
            
        } catch (e: Exception) {
            Result.failure(e)
        }
    }
    
    private fun parseStatusResponse(line: String): MailboxInfo {
        val nameStart = line.indexOf('"') + 1
        val nameEnd = line.indexOf('"', nameStart)
        val name = if (nameStart > 0 && nameEnd > nameStart) {
            line.substring(nameStart, nameEnd)
        } else ""
        
        val statusStr = line.substringAfter("(").substringBefore(")")
        val parts = statusStr.split(" ")
        
        var messages = 0; var recent = 0; var unseen = 0
        var uidNext = 0L; var uidValidity = 0L
        
        var i = 0
        while (i < parts.size - 1) {
            when (parts[i]) {
                "MESSAGES" -> messages = parts[i + 1].toInt()
                "RECENT" -> recent = parts[i + 1].toInt()
                "UNSEEN" -> unseen = parts[i + 1].toInt()
                "UIDNEXT" -> uidNext = parts[i + 1].toLong()
                "UIDVALIDITY" -> uidValidity = parts[i + 1].toLong()
            }
            i += 2
        }
        
        return MailboxInfo(
            name = name,
            exists = messages,
            recent = recent,
            unseen = unseen,
            uidNext = uidNext,
            uidValidity = uidValidity
        )
    }
    
    /**
     * Subscribes to a mailbox.
     */
    suspend fun subscribeMailbox(name: String): Result<Unit> = withContext(Dispatchers.IO) {
        try {
            requireAuth()
            val response = executeCommand("SUBSCRIBE ${quoteString(name)}")
            if (response.type == ImapResponseType.OK) Result.success(Unit)
            else Result.failure(ImapCommandException(response.type, response.message))
        } catch (e: Exception) {
            Result.failure(e)
        }
    }
    
    /**
     * Unsubscribes from a mailbox.
     */
    suspend fun unsubscribeMailbox(name: String): Result<Unit> = withContext(Dispatchers.IO) {
        try {
            requireAuth()
            val response = executeCommand("UNSUBSCRIBE ${quoteString(name)}")
            if (response.type == ImapResponseType.OK) Result.success(Unit)
            else Result.failure(ImapCommandException(response.type, response.message))
        } catch (e: Exception) {
            Result.failure(e)
        }
    }
    
    // ========================================================================
    // MESSAGE FETCH OPERATIONS (~1200 lines)
    // ========================================================================
    
    /**
     * Fetches messages with specified attributes.
     * 
     * @param sequenceSet Message sequence numbers (e.g., "1:10", "1,3,5", "*")
     * @param attributes Fetch attributes to retrieve
     * @param useUid Whether to interpret sequenceSet as UIDs
     * @return List of fetch responses
     */
    suspend fun fetchMessages(
        sequenceSet: String,
        attributes: List<FetchAttribute> = listOf(
            FetchAttribute.UID, FetchAttribute.FLAGS,
            FetchAttribute.INTERNALDATE, FetchAttribute.RFC822_SIZE,
            FetchAttribute.ENVELOPE, FetchAttribute.BODYSTRUCTURE
        ),
        useUid: Boolean = false
    ): Result<List<FetchResponse>> = withContext(Dispatchers.IO) {
        try {
            requireSelected()
            
            val attrStr = buildFetchAttributeString(attributes)
            val uidPrefix = if (useUid) "UID " else ""
            val tag = nextTag()
            
            sendRaw("$tag ${uidPrefix}FETCH $sequenceSet $attrStr")
            
            val responses = parseFetchResponses(tag, attributes)
            Result.success(responses)
            
        } catch (e: Exception) {
            Result.failure(e)
        }
    }
    
    /**
     * Fetches a specific MIME body section.
     */
    suspend fun fetchBodySection(
        sequenceSet: String,
        section: String = "",
        useUid: Boolean = false,
        peek: Boolean = true
    ): Result<List<FetchResponse>> = withContext(Dispatchers.IO) {
        try {
            requireSelected()
            
            val sectionSpec = if (section.isEmpty()) "[]" else "[$section]"
            val command = if (peek) "BODY.PEEK$sectionSpec" else "BODY$sectionSpec"
            val uidPrefix = if (useUid) "UID " else ""
            
            val tag = nextTag()
            sendRaw("$tag ${uidPrefix}FETCH $sequenceSet ($command)")
            
            val responses = mutableListOf<FetchResponse>()
            
            while (true) {
                val line = reader!!.readLine() ?: break
                if (line.startsWith("*") && line.contains("FETCH")) {
                    responses.add(parseSingleFetchResponse(line, listOf(FetchAttribute.BODY), reader))
                } else if (line.startsWith("$tag OK")) break
                else if (line.startsWith("$tag NO") || line.startsWith("$tag BAD")) {
                    throw ImapCommandException(
                        if (line.startsWith("$tag NO")) ImapResponseType.NO else ImapResponseType.BAD,
                        line
                    )
                }
            }
            
            Result.success(responses)
            
        } catch (e: Exception) {
            Result.failure(e)
        }
    }
    
    private fun buildFetchAttributeString(attributes: List<FetchAttribute>): String {
        val macros = mapOf(
            "ALL" to listOf(FetchAttribute.FLAGS, FetchAttribute.INTERNALDATE,
                FetchAttribute.RFC822_SIZE, FetchAttribute.ENVELOPE),
            "FAST" to listOf(FetchAttribute.FLAGS, FetchAttribute.INTERNALDATE,
                FetchAttribute.RFC822_SIZE),
            "FULL" to listOf(FetchAttribute.FLAGS, FetchAttribute.INTERNALDATE,
                FetchAttribute.RFC822_SIZE, FetchAttribute.ENVELOPE,
                FetchAttribute.BODYSTRUCTURE)
        )
        
        // Check for macro expansion
        for ((macro, attrs) in macros) {
            if (attributes.containsAll(attrs) && attributes.size == attrs.size) {
                return macro
            }
        }
        
        val attrStrings = attributes.map {
            when (it) {
                FetchAttribute.BODY -> "BODY[]"
                FetchAttribute.BODY_PEEK -> "BODY.PEEK[]"
                else -> it.attr
            }
        }
        return "(${attrStrings.joinToString(" ")})"
    }
    
    private suspend fun parseFetchResponses(
        tag: String,
        attributes: List<FetchAttribute>
    ): List<FetchResponse> {
        val responses = mutableListOf<FetchResponse>()
        
        while (true) {
            val line = reader!!.readLine() ?: break
            
            if (line.startsWith("*") && line.contains("FETCH")) {
                responses.add(parseSingleFetchResponse(line, attributes, reader))
            } else if (line.startsWith("$tag OK")) {
                break
            } else if (line.startsWith("$tag NO") || line.startsWith("$tag BAD")) {
                throw ImapCommandException(
                    if (line.startsWith("$tag NO")) ImapResponseType.NO else ImapResponseType.BAD,
                    line
                )
            }
        }
        
        return responses
    }
    
    private suspend fun parseSingleFetchResponse(
        initialLine: String,
        attributes: List<FetchAttribute>,
        reader: BufferedReader?
    ): FetchResponse {
        var seqNum = 0L; var uid: Long? = null
        var flags: Set<MailFlag>? = null
        var internalDate: Date? = null
        var size: Long? = null
        var envelope: EmailEnvelope? = null
        var bodyStructure: BodyStructure? = null
        var body: ByteArray? = null
        var modSeq: Long? = null
        var preview: String? = null
        
        // Parse sequence number: * 123 FETCH (...)
        Regex("\\* (\\d+) FETCH").find(initialLine)?.let {
            seqNum = it.groupValues[1].toLong()
        }
        
        var currentLine = initialLine
        
        // Handle multi-line responses
        while (true) {
            // Parse each attribute
            when {
                currentLine.contains("UID ") -> {
                    uid = currentLine.substringAfter("UID ").trim().split(" ").firstOrNull()?.toLongOrNull()
                }
                currentLine.contains("FLAGS (") -> {
                    val flagsStr = currentLine.substringAfter("FLAGS (").substringBefore(")")
                    flags = parseFlagsString(flagsStr)
                }
                currentLine.contains("INTERNALDATE \"") -> {
                    val dateStr = currentLine.substringAfter("\"").substringBefore("\"")
                    internalDate = parseImapDate(dateStr)
                }
                currentLine.contains("RFC822.SIZE ") -> {
                    size = currentLine.substringAfter("RFC822.SIZE ").trim().split(" ").firstOrNull()?.toLongOrNull()
                }
                currentLine.contains("ENVELOPE (") -> {
                    envelope = parseEnvelope(currentLine, reader)
                }
                currentLine.contains("BODYSTRUCTURE (") -> {
                    bodyStructure = parseBodyStructure(currentLine, reader)
                }
                currentLine.contains("BODY[") -> {
                    body = parseLiteralBody(currentLine, reader)
                }
                currentLine.contains("MODSEQ (") -> {
                    Regex("MODSEQ \\((\\d+)\\)").find(currentLine)?.let {
                        modSeq = it.groupValues[1].toLong()
                    }
                }
                currentLine.contains("PREVIEW ") -> {
                    preview = currentLine.substringAfter("PREVIEW ").trim().removeSurrounding("\"")
                }
            }
            
            // Check if we need to read more
            if (currentLine.contains("{") && !currentLine.endsWith("}")) {
                currentLine = reader?.readLine() ?: break
            } else {
                break
            }
        }
        
        return FetchResponse(
            seqNum = seqNum, uid = uid, flags = flags,
            internalDate = internalDate, size = size,
            envelope = envelope, bodyStructure = bodyStructure,
            body = body, modSeq = modSeq, preview = preview
        )
    }
    
    private fun parseFlagsString(flagsStr: String): Set<MailFlag> {
        return flagsStr.split(" ").filter { it.isNotEmpty() }.mapNotNull { flag ->
            when (flag.lowercase()) {
                "\\seen" -> MailFlag.SEEN
                "\\answered" -> MailFlag.ANSWERED
                "\\flagged" -> MailFlag.FLAGGED
                "\\deleted" -> MailFlag.DELETED
                "\\draft" -> MailFlag.DRAFT
                "\\recent" -> MailFlag.RECENT
                "\$forwarded" -> MailFlag.FORWARDED
                "\$junk" -> MailFlag.JUNK
                "\$notjunk" -> MailFlag.NOT_JUNK
                "\$important" -> MailFlag.IMPORTANT
                "\$phishing" -> MailFlag.PHISHING
                else -> null
            }
        }.toSet()
    }
    
    private fun parseImapDate(dateStr: String): Date? {
        // IMAP date format: "01-Jan-2023 12:00:00 +0000"
        val formats = listOf(
            SimpleDateFormat("dd-MMM-yyyy HH:mm:ss Z", Locale.US),
            SimpleDateFormat("dd-MMM-yyyy HH:mm:ss ZZZZ", Locale.US),
            SimpleDateFormat("d-MMM-yyyy HH:mm:ss Z", Locale.US)
        )
        for (format in formats) {
            try {
                return format.parse(dateStr)
            } catch (_: ParseException) {}
        }
        return null
    }
    
    private suspend fun parseEnvelope(
        initialLine: String,
        reader: BufferedReader?
    ): EmailEnvelope {
        // Simplified envelope parsing
        // Full implementation would parse nested parenthesized lists
        return EmailEnvelope(
            date = extractQuoted(initialLine),
            subject = extractQuoted(initialLine),
            from = parseAddressList(initialLine),
            to = parseAddressList(initialLine),
            messageId = extractQuoted(initialLine)
        )
    }
    
    private fun extractQuoted(data: String): String? {
        val match = Regex("\"([^\"]*)\"").find(data)
        return match?.groupValues?.get(1)
    }
    
    private fun parseAddressList(data: String): List<EmailAddress> {
        // Simplified address list parsing
        val addresses = mutableListOf<EmailAddress>()
        val pattern = Regex("\\(\"([^\"]*)\" NIL \"([^\"]*)\" \"([^\"]*)\"\\)")
        pattern.findAll(data).forEach { match ->
            addresses.add(
                EmailAddress(
                    name = match.groupValues[1],
                    mailbox = match.groupValues[2],
                    host = match.groupValues[3]
                )
            )
        }
        return addresses
    }
    
    private suspend fun parseBodyStructure(
        initialLine: String,
        reader: BufferedReader?
    ): BodyStructure {
        // Simplified body structure parsing
        // Full implementation would recursively parse MIME parts
        val parts = initialLine.split(" ")
        if (parts.size < 2) return BodyStructure("text", "plain", size = 0)
        
        return BodyStructure(
            type = parts.getOrElse(0) { "text" }.removeSurrounding("\"").lowercase(),
            subtype = parts.getOrElse(1) { "plain" }.removeSurrounding("\"").lowercase(),
            size = parts.getOrElse(6) { "0" }.toLongOrNull() ?: 0,
            encoding = parts.getOrElse(5) { "7bit" }.removeSurrounding("\"")
        )
    }
    
    private suspend fun parseLiteralBody(
        currentLine: String,
        reader: BufferedReader?
    ): ByteArray? {
        val sizeMatch = Regex("\\{(\\d+)\\}").find(currentLine)
        return sizeMatch?.let { match ->
            val size = match.groupValues[1].toIntOrNull() ?: return null
            if (size > MAX_LITERAL_SIZE) {
                throw ImapLimitException("Literal too large: $size bytes", MAX_LITERAL_SIZE)
            }
            val buffer = CharArray(size)
            reader?.read(buffer) ?: return null
            String(buffer).toByteArray()
        }
    }
    
    // ========================================================================
    // SEARCH OPERATIONS (~500 lines)
    // ========================================================================
    
    /**
     * Searches for messages matching given criteria.
     */
    suspend fun searchMessages(
        criteria: SearchCriteria,
        useUid: Boolean = false
    ): Result<List<Long>> = withContext(Dispatchers.IO) {
        try {
            requireSelected()
            
            val searchStr = buildSearchString(criteria)
            val uidPrefix = if (useUid) "UID " else ""
            val tag = nextTag()
            
            sendRaw("$tag ${uidPrefix}SEARCH $searchStr")
            
            val ids = mutableListOf<Long>()
            
            while (true) {
                val line = reader!!.readLine() ?: break
                if (line.startsWith("* SEARCH")) {
                    val idStrs = line.substringAfter("SEARCH").trim().split(" ").filter { it.isNotEmpty() }
                    ids.addAll(idStrs.mapNotNull { it.toLongOrNull() })
                } else if (line.startsWith("$tag OK")) break
                else if (line.startsWith("$tag NO") || line.startsWith("$tag BAD")) {
                    throw ImapCommandException(
                        if (line.startsWith("$tag NO")) ImapResponseType.NO else ImapResponseType.BAD,
                        line
                    )
                }
            }
            
            Result.success(ids)
            
        } catch (e: Exception) {
            Result.failure(e)
        }
    }
    
    private fun buildSearchString(criteria: SearchCriteria): String {
        val charset = criteria.charset ?: "UTF-8"
        val parts = mutableListOf<String>()
        
        criteria.keys.forEachIndexed { i, key ->
            val value = criteria.values.getOrNull(i) ?: ""
            when (key) {
                SearchKey.ALL -> parts.add("ALL")
                SearchKey.ANSWERED -> parts.add("ANSWERED")
                SearchKey.SEEN -> parts.add("SEEN")
                SearchKey.UNSEEN -> parts.add("UNSEEN")
                SearchKey.DELETED -> parts.add("DELETED")
                SearchKey.FLAGGED -> parts.add("FLAGGED")
                SearchKey.DRAFT -> parts.add("DRAFT")
                SearchKey.RECENT -> parts.add("RECENT")
                SearchKey.NEW -> parts.add("NEW")
                SearchKey.OLD -> parts.add("OLD")
                SearchKey.SUBJECT -> parts.add("SUBJECT \"$value\"")
                SearchKey.FROM -> parts.add("FROM \"$value\"")
                SearchKey.TO -> parts.add("TO \"$value\"")
                SearchKey.CC -> parts.add("CC \"$value\"")
                SearchKey.BCC -> parts.add("BCC \"$value\"")
                SearchKey.BODY -> parts.add("BODY \"$value\"")
                SearchKey.TEXT -> parts.add("TEXT \"$value\"")
                SearchKey.HEADER -> {
                    val (header, hValue) = value.split(":", limit = 2)
                    parts.add("HEADER $header \"${hValue.trim()}\"")
                }
                SearchKey.BEFORE -> parts.add("BEFORE $value")
                SearchKey.ON -> parts.add("ON $value")
                SearchKey.SINCE -> parts.add("SINCE $value")
                SearchKey.SENTBEFORE -> parts.add("SENTBEFORE $value")
                SearchKey.SENTON -> parts.add("SENTON $value")
                SearchKey.SENTSINCE -> parts.add("SENTSINCE $value")
                SearchKey.LARGER -> parts.add("LARGER $value")
                SearchKey.SMALLER -> parts.add("SMALLER $value")
                SearchKey.UID -> parts.add("UID $value")
                SearchKey.KEYWORD -> parts.add("KEYWORD $value")
                SearchKey.NOT -> parts.add("NOT ${buildSearchString(criteria.copy(keys = criteria.keys.drop(1)))}")
                SearchKey.OR -> parts.add("OR ${buildSearchString(criteria.copy(keys = criteria.keys.drop(1)))} ${buildSearchString(criteria.copy(keys = criteria.keys.drop(2)))}")
                SearchKey.YOUNGER -> parts.add("YOUNGER $value")
                SearchKey.OLDER -> parts.add("OLDER $value")
                else -> parts.add(key.name)
            }
        }
        
        return "CHARSET $charset ${parts.joinToString(" ")}"
    }
    
    // ========================================================================
    // FLAGS & STORE OPERATIONS (~400 lines)
    // ========================================================================
    
    /**
     * Modifies message flags.
     */
    suspend fun storeFlags(
        sequenceSet: String,
        flags: Set<MailFlag>,
        operation: StoreOp = StoreOp.ADD_FLAGS,
        useUid: Boolean = false
    ): Result<Unit> = withContext(Dispatchers.IO) {
        try {
            requireSelected()
            
            val flagsStr = buildFlagsString(flags)
            val uidPrefix = if (useUid) "UID " else ""
            val response = executeCommand(
                "${uidPrefix}STORE $sequenceSet ${operation.op} $flagsStr"
            )
            
            if (response.type == ImapResponseType.OK) Result.success(Unit)
            else Result.failure(ImapCommandException(response.type, response.message))
            
        } catch (e: Exception) {
            Result.failure(e)
        }
    }
    
    private fun buildFlagsString(flags: Set<MailFlag>): String {
        val flagStrs = flags.map { it.imapFlag }
        return "(${flagStrs.joinToString(" ")})"
    }
    
    // ========================================================================
    // MESSAGE MANIPULATION (~500 lines)
    // ========================================================================
    
    /**
     * Appends a message to a mailbox.
     */
    suspend fun appendMessage(
        mailbox: String,
        message: ByteArray,
        flags: Set<MailFlag> = emptySet(),
        date: Date? = null
    ): Result<Long> = withContext(Dispatchers.IO) {
        try {
            requireAuth()
            
            val flagsStr = if (flags.isNotEmpty()) " ${buildFlagsString(flags)}" else ""
            val dateStr = date?.let {
                val sdf = SimpleDateFormat("dd-MMM-yyyy HH:mm:ss Z", Locale.US)
                " \"${sdf.format(it)}\""
            } ?: ""
            
            val tag = nextTag()
            sendRaw("$tag APPEND ${quoteString(mailbox)}$flagsStr$dateStr {${message.size}}")
            
            val continuation = readResponseInternal()
            if (continuation.type != ImapResponseType.CONTINUATION) {
                return@withContext Result.failure(ImapException("Expected continuation"))
            }
            
            rawOutput?.write(message)
            rawOutput?.flush()
            sendRaw("")
            
            val response = readResponseInternal()
            if (response.type == ImapResponseType.OK) {
                val uid = response.responseCode?.let { code ->
                    if (code.startsWith("APPENDUID")) {
                        code.split(" ").lastOrNull()?.toLongOrNull()
                    } else null
                }
                Result.success(uid ?: 0L)
            } else {
                Result.failure(ImapCommandException(response.type, response.message))
            }
            
        } catch (e: Exception) {
            Result.failure(e)
        }
    }
    
    /**
     * Copies messages to another mailbox.
     */
    suspend fun copyMessages(
        sequenceSet: String,
        destination: String,
        useUid: Boolean = false
    ): Result<Unit> = withContext(Dispatchers.IO) {
        try {
            requireSelected()
            val uidPrefix = if (useUid) "UID " else ""
            val response = executeCommand(
                "${uidPrefix}COPY $sequenceSet ${quoteString(destination)}"
            )
            if (response.type == ImapResponseType.OK) Result.success(Unit)
            else Result.failure(ImapCommandException(response.type, response.message))
        } catch (e: Exception) {
            Result.failure(e)
        }
    }
    
    /**
     * Moves messages to another mailbox.
     * Uses MOVE extension if available, falls back to COPY+DELETE+EXPUNGE.
     */
    suspend fun moveMessages(
        sequenceSet: String,
        destination: String,
        useUid: Boolean = false
    ): Result<Unit> = withContext(Dispatchers.IO) {
        try {
            requireSelected()
            
            if (capabilities.get().move) {
                val uidPrefix = if (useUid) "UID " else ""
                val response = executeCommand(
                    "${uidPrefix}MOVE $sequenceSet ${quoteString(destination)}"
                )
                return@withContext if (response.type == ImapResponseType.OK) {
                    Result.success(Unit)
                } else {
                    Result.failure(ImapCommandException(response.type, response.message))
                }
            }
            
            // Fallback: Copy + Delete + Expunge
            copyMessages(sequenceSet, destination, useUid).getOrThrow()
            storeFlags(sequenceSet, setOf(MailFlag.DELETED), StoreOp.ADD_FLAGS, useUid).getOrThrow()
            expunge().getOrThrow()
            
            Result.success(Unit)
            
        } catch (e: Exception) {
            Result.failure(e)
        }
    }
    
    /**
     * Expunges all messages marked as deleted.
     */
    suspend fun expunge(): Result<List<Long>> = withContext(Dispatchers.IO) {
        try {
            requireSelected()
            
            val tag = nextTag()
            sendRaw("$tag EXPUNGE")
            
            val expunged = mutableListOf<Long>()
            
            while (true) {
                val line = reader!!.readLine() ?: break
                if (line.contains("EXPUNGE")) {
                    Regex("\\* (\\d+) EXPUNGE").find(line)?.let {
                        expunged.add(it.groupValues[1].toLong())
                    }
                } else if (line.startsWith("$tag OK")) break
                else if (line.startsWith("$tag NO") || line.startsWith("$tag BAD")) {
                    throw ImapCommandException(
                        if (line.startsWith("$tag NO")) ImapResponseType.NO else ImapResponseType.BAD,
                        line
                    )
                }
            }
            
            Result.success(expunged)
            
        } catch (e: Exception) {
            Result.failure(e)
        }
    }
    
    /**
     * Closes the selected mailbox, expunging deleted messages.
     */
    suspend fun closeMailbox(): Result<Unit> = withContext(Dispatchers.IO) {
        try {
            requireSelected()
            val response = executeCommand("CLOSE")
            if (response.type == ImapResponseType.OK) {
                state.set(ImapState.AUTHENTICATED)
                selectedMailbox.set(null)
                notifyEvent(ConnectionEvent.MAILBOX_CLOSED)
                Result.success(Unit)
            } else {
                Result.failure(ImapCommandException(response.type, response.message))
            }
        } catch (e: Exception) {
            Result.failure(e)
        }
    }
    
    /**
     * Unselects the current mailbox without expunging (RFC 3691).
     */
    suspend fun unselectMailbox(): Result<Unit> = withContext(Dispatchers.IO) {
        try {
            requireSelected()
            if (!capabilities.get().unselect) {
                return@withContext Result.failure(ImapException("UNSELECT not supported"))
            }
            val response = executeCommand("UNSELECT")
            if (response.type == ImapResponseType.OK) {
                state.set(ImapState.AUTHENTICATED)
                selectedMailbox.set(null)
                Result.success(Unit)
            } else {
                Result.failure(ImapCommandException(response.type, response.message))
            }
        } catch (e: Exception) {
            Result.failure(e)
        }
    }
    
    // ========================================================================
    // SORT & THREAD (~400 lines)
    // ========================================================================
    
    /**
     * Sorts messages using SORT extension (RFC 5256).
     */
    suspend fun sortMessages(
        criteria: List<SortCriterion>,
        searchCriteria: SearchCriteria? = null,
        useUid: Boolean = false
    ): Result<List<Long>> = withContext(Dispatchers.IO) {
        try {
            requireSelected()
            
            if (!capabilities.get().sort) {
                return@withContext Result.failure(ImapException("SORT not supported"))
            }
            
            val sortStr = criteria.joinToString(" ") { it.crit }
            val searchStr = searchCriteria?.let { buildSearchString(it) } ?: "ALL"
            val uidPrefix = if (useUid) "UID " else ""
            
            val tag = nextTag()
            sendRaw("$tag ${uidPrefix}SORT ($sortStr) UTF-8 $searchStr")
            
            val ids = mutableListOf<Long>()
            
            while (true) {
                val line = reader!!.readLine() ?: break
                if (line.startsWith("* SORT")) {
                    val idStrs = line.substringAfter("SORT").trim().split(" ").filter { it.isNotEmpty() }
                    ids.addAll(idStrs.mapNotNull { it.toLongOrNull() })
                } else if (line.startsWith("$tag OK")) break
                else if (line.startsWith("$tag NO") || line.startsWith("$tag BAD")) {
                    throw ImapCommandException(
                        if (line.startsWith("$tag NO")) ImapResponseType.NO else ImapResponseType.BAD,
                        line
                    )
                }
            }
            
            Result.success(ids)
            
        } catch (e: Exception) {
            Result.failure(e)
        }
    }
    
    /**
     * Threads messages using THREAD extension (RFC 5256).
     */
    suspend fun threadMessages(
        algorithm: ThreadAlgorithm = ThreadAlgorithm.REFERENCES,
        searchCriteria: SearchCriteria? = null,
        useUid: Boolean = false
    ): Result<List<List<Long>>> = withContext(Dispatchers.IO) {
        try {
            requireSelected()
            
            if (!capabilities.get().thread.contains(algorithm)) {
                return@withContext Result.failure(ImapException("$algorithm threading not supported"))
            }
            
            val searchStr = searchCriteria?.let { buildSearchString(it) } ?: "ALL"
            val uidPrefix = if (useUid) "UID " else ""
            
            val tag = nextTag()
            sendRaw("$tag ${uidPrefix}THREAD ${algorithm.algo} UTF-8 $searchStr")
            
            val threads = mutableListOf<List<Long>>()
            
            while (true) {
                val line = reader!!.readLine() ?: break
                if (line.startsWith("* THREAD")) {
                    val threadData = line.substringAfter("THREAD").trim()
                    threads.addAll(parseThreadData(threadData))
                } else if (line.startsWith("$tag OK")) break
                else if (line.startsWith("$tag NO") || line.startsWith("$tag BAD")) {
                    throw ImapCommandException(
                        if (line.startsWith("$tag NO")) ImapResponseType.NO else ImapResponseType.BAD,
                        line
                    )
                }
            }
            
            Result.success(threads)
            
        } catch (e: Exception) {
            Result.failure(e)
        }
    }
    
    private fun parseThreadData(data: String): List<List<Long>> {
        val threads = mutableListOf<List<Long>>()
        val stack = Stack<MutableList<Long>>()
        val tokens = data.replace("(", " ( ").replace(")", " ) ").split("\\s+".toRegex())
        
        for (token in tokens) {
            when (token) {
                "(" -> stack.push(mutableListOf())
                ")" -> {
                    if (stack.isNotEmpty()) {
                        val thread = stack.pop()
                        if (thread.isNotEmpty()) {
                            if (stack.isEmpty()) threads.add(thread)
                            else stack.peek().addAll(thread)
                        }
                    }
                }
                else -> {
                    token.toLongOrNull()?.let {
                        if (stack.isEmpty()) stack.push(mutableListOf())
                        stack.peek().add(it)
                    }
                }
            }
        }
        
        return threads
    }
    
    // ========================================================================
    // IDLE & REAL-TIME UPDATES (~600 lines)
    // ========================================================================
    
    /**
     * Enters IDLE mode to receive real-time updates (RFC 2177).
     */
    suspend fun startIdle(callback: IdleCallback): Result<Unit> = idleLock.withLock {
        try {
            requireSelected()
            
            if (!capabilities.get().idle) {
                return Result.failure(ImapException("IDLE not supported"))
            }
            
            idleCallbacks.add(callback)
            
            if (idleCallbacks.size > 1) {
                return Result.success(Unit) // Already in IDLE
            }
            
            val tag = nextTag()
            sendRaw("$tag IDLE")
            
            val response = readResponseInternal()
            if (response.type != ImapResponseType.CONTINUATION) {
                idleCallbacks.clear()
                return Result.failure(ImapException("IDLE initiation failed"))
            }
            
            notifyEvent(ConnectionEvent.IDLE_STARTED)
            
            // Start monitoring coroutine
            idleJob = CoroutineScope(Dispatchers.IO).launch {
                try {
                    withTimeout(IDLE_TIMEOUT_MS) {
                        while (isActive) {
                            val line = reader?.readLine() ?: break
                            
                            if (line.startsWith("*")) {
                                val notification = parseNotification(line)
                                idleCallbacks.forEach { cb ->
                                    try { cb(notification) }
                                    catch (e: Exception) {
                                        logger.warn("IDLE callback error", e)
                                    }
                                }
                            }
                        }
                    }
                } catch (e: TimeoutCancellationException) {
                    logger.debug("IDLE timeout, refreshing")
                    stopIdleInternal()
                    startIdle(callback) // Re-start IDLE
                } catch (e: Exception) {
                    logger.error("IDLE monitoring error", e)
                }
            }
            
            Result.success(Unit)
            
        } catch (e: Exception) {
            Result.failure(e)
        }
    }
    
    /**
     * Stops IDLE mode.
     */
    suspend fun stopIdle(): Result<Unit> = idleLock.withLock {
        try {
            stopIdleInternal()
            Result.success(Unit)
        } catch (e: Exception) {
            Result.failure(e)
        }
    }
    
    private suspend fun stopIdleInternal() {
        idleJob?.cancel()
        idleJob = null
        
        try {
            sendRaw("DONE")
            val response = readResponseInternal()
            logger.debug("IDLE stopped: ${response.type}")
        } catch (e: Exception) {
            logger.debug("Error stopping IDLE: ${e.message}")
        }
        
        idleCallbacks.clear()
        notifyEvent(ConnectionEvent.IDLE_STOPPED)
    }
    
    private fun stopIdleJob() {
        idleJob?.cancel()
        idleJob = null
        idleCallbacks.clear()
    }
    
    private fun parseNotification(line: String): ImapNotification {
        return when {
            line.contains("EXISTS") -> {
                ImapNotification.Exists(extractNumber(line))
            }
            line.contains("EXPUNGE") -> {
                ImapNotification.Expunge(extractNumber(line).toLong())
            }
            line.contains("FETCH") -> {
                ImapNotification.Fetch(line)
            }
            line.contains("RECENT") -> {
                ImapNotification.Recent(extractNumber(line))
            }
            else -> ImapNotification.Unknown(line)
        }
    }
    
    sealed class ImapNotification {
        data class Exists(val count: Int) : ImapNotification()
        data class Expunge(val seqNum: Long) : ImapNotification()
        data class Fetch(val data: String) : ImapNotification()
        data class Recent(val count: Int) : ImapNotification()
        data class Unknown(val raw: String) : ImapNotification()
    }
    
    // ========================================================================
    // CAPABILITIES & NAMESPACE (~300 lines)
    // ========================================================================
    
    private suspend fun fetchCapabilities() {
        val response = executeCommand("CAPABILITY", skipLock = true)
        if (response.type == ImapResponseType.OK) {
            parseCapabilities(response.message)
        }
    }
    
    private fun parseCapabilities(capStr: String) {
        val caps = capStr.substringAfter("CAPABILITY")
            .substringBefore("\n")
            .trim()
            .split(" ")
            .filter { it.isNotEmpty() }
            .toSet()
        
        val authMethods = caps.filter { it.startsWith("AUTH=") }
            .map { it.removePrefix("AUTH=") }
            .mapNotNull { methodName ->
                when (methodName) {
                    "PLAIN" -> AuthMethod.PLAIN
                    "LOGIN" -> AuthMethod.LOGIN
                    "CRAM-MD5" -> AuthMethod.CRAM_MD5
                    "SCRAM-SHA-1" -> AuthMethod.SCRAM_SHA1
                    "SCRAM-SHA-256" -> AuthMethod.SCRAM_SHA256
                    "XOAUTH2" -> AuthMethod.XOAUTH2
                    "OAUTHBEARER" -> AuthMethod.OAUTHBEARER
                    "NTLM" -> AuthMethod.NTLM
                    "GSSAPI" -> AuthMethod.GSSAPI
                    else -> null
                }
            }
        
        val threadAlgos = caps.filter { it.startsWith("THREAD=") }
            .map { it.removePrefix("THREAD="") }
            .mapNotNull { algo ->
                when (algo) {
                    "ORDEREDSUBJECT" -> ThreadAlgorithm.ORDEREDSUBJECT
                    "REFERENCES" -> ThreadAlgorithm.REFERENCES
                    "REFS" -> ThreadAlgorithm.REFS
                    else -> null
                }
            }
        
        capabilities.set(
            ImapCapability(
                imap4rev1 = caps.contains("IMAP4rev1"),
                imap4rev2 = caps.contains("IMAP4rev2"),
                auth = authMethods.toSet(),
                startTls = caps.contains("STARTTLS"),
                idle = caps.contains("IDLE"),
                namespace = caps.contains("NAMESPACE"),
                uidPlus = caps.contains("UIDPLUS"),
                condStore = caps.contains("CONDSTORE"),
                qResync = caps.contains("QRESYNC"),
                enable = caps.contains("ENABLE"),
                compress = caps.contains("COMPRESS=DEFLATE"),
                sort = caps.contains("SORT"),
                thread = threadAlgos.toSet(),
                move = caps.contains("MOVE"),
                unselect = caps.contains("UNSELECT"),
                children = caps.contains("CHILDREN"),
                multiAppend = caps.contains("MULTIAPPEND"),
                esearch = caps.contains("ESEARCH"),
                searchRes = caps.contains("SEARCHRES"),
                within = caps.contains("WITHIN"),
                listExtended = caps.contains("LIST-EXTENDED"),
                listStatus = caps.contains("LIST-STATUS"),
                specialUse = caps.contains("SPECIAL-USE"),
                metadata = caps.contains("METADATA"),
                notify = caps.contains("NOTIFY"),
                saslIR = caps.contains("SASL-IR"),
                rights = caps.contains("MYRIGHTS"),
                objectId = caps.contains("OBJECTID"),
                replace = caps.contains("REPLACE"),
                saveDate = caps.contains("SAVEDATE"),
                preview = caps.contains("PREVIEW"),
                literalPlus = caps.contains("LITERAL+"),
                literalMinus = caps.contains("LITERAL-")
            )
        )
    }
    
    private suspend fun sendIdCommand() {
        try {
            val idParams = mapOf(
                "name" to "SuperEmail",
                "version" to "3.2.1",
                "os" to "Android",
                "os-version" to android.os.Build.VERSION.RELEASE,
                "vendor" to "SuperEmail Inc.",
                "support-url" to "https://superemail.com/support"
            )
            val idStr = idParams.map { "\"${it.key}\" \"${it.value}\"" }.joinToString(" ")
            executeCommand("ID ($idStr)", skipLock = true)
        } catch (e: Exception) {
            logger.debug("ID command failed: ${e.message}")
        }
    }
    
    /**
     * Gets namespace information (RFC 2342).
     */
    suspend fun getNamespaces(): Result<Namespace> = withContext(Dispatchers.IO) {
        try {
            requireAuth()
            
            if (!capabilities.get().namespace) {
                return@withContext Result.failure(ImapException("NAMESPACE not supported"))
            }
            
            val tag = nextTag()
            sendRaw("$tag NAMESPACE")
            
            var namespace: Namespace? = null
            
            while (true) {
                val line = reader!!.readLine() ?: break
                if (line.startsWith("* NAMESPACE")) {
                    namespace = parseNamespaceResponse(line)
                } else if (line.startsWith("$tag OK")) break
                else if (line.startsWith("$tag NO") || line.startsWith("$tag BAD")) {
                    throw ImapCommandException(
                        if (line.startsWith("$tag NO")) ImapResponseType.NO else ImapResponseType.BAD,
                        line
                    )
                }
            }
            
            Result.success(namespace ?: Namespace())
            
        } catch (e: Exception) {
            Result.failure(e)
        }
    }
    
    private fun parseNamespaceResponse(line: String): Namespace {
        // Parse: * NAMESPACE (("" "/")) (("~" "/")) (("#shared/" "/"))
        val parts = line.substringAfter("NAMESPACE ").trim()
        val sections = splitNamespaceSections(parts)
        
        return Namespace(
            personal = parseNamespaceEntries(sections.getOrElse(0) { "NIL" }),
            otherUsers = parseNamespaceEntries(sections.getOrElse(1) { "NIL" }),
            shared = parseNamespaceEntries(sections.getOrElse(2) { "NIL" })
        )
    }
    
    private fun splitNamespaceSections(data: String): List<String> {
        val sections = mutableListOf<String>()
        var depth = 0
        var current = StringBuilder()
        
        for (char in data) {
            when (char) {
                '(' -> {
                    depth++
                    current.append(char)
                }
                ')' -> {
                    depth--
                    current.append(char)
                    if (depth == 0) {
                        sections.add(current.toString().trim())
                        current = StringBuilder()
                    }
                }
                else -> current.append(char)
            }
        }
        
        return sections
    }
    
    private fun parseNamespaceEntries(data: String): List<NamespaceEntry> {
        if (data == "NIL" || data.isBlank()) return emptyList()
        
        val entries = mutableListOf<NamespaceEntry>()
        val pattern = Regex("\\(\"([^\"]*)\"\\s*\"([^\"]*)\"\\)")
        
        pattern.findAll(data).forEach { match ->
            entries.add(
                NamespaceEntry(
                    prefix = match.groupValues[1],
                    delimiter = match.groupValues[2]
                )
            )
        }
        
        return entries
    }
    
    // ========================================================================
    // COMMAND EXECUTION & RESPONSE HANDLING (~400 lines)
    // ========================================================================
    
    private fun nextTag(): String = "A${tagCounter.incrementAndGet()}"
    
    private suspend fun executeCommand(
        command: String,
        skipLock: Boolean = false
    ): ImapResponse {
        val startTime = System.currentTimeMillis()
        metrics.recordCommand()
        
        val response = if (skipLock) {
            sendCommandAndWait(command)
        } else {
            commandLock.withLock {
                sendCommandAndWait(command)
            }
        }
        
        val elapsed = System.currentTimeMillis() - startTime
        metrics.recordResponseTime(elapsed)
        
        if (response.type == ImapResponseType.NO || response.type == ImapResponseType.BAD) {
            metrics.recordFailedCommand()
        }
        
        return response
    }
    
    private suspend fun sendCommandAndWait(command: String): ImapResponse {
        val tag = nextTag()
        sendRaw("$tag $command")
        return readResponseForTag(tag)
    }
    
    private fun sendRaw(data: String) {
        if (config.debugMode) {
            logger.debug(">> $data")
        }
        val w = writer ?: throw ImapConnectionException("Not connected")
        w.write(data)
        w.write("\r\n")
        w.flush()
        metrics.recordBytesSent(data.length.toLong() + 2)
        metrics.recordActivity()
    }
    
    private suspend fun readResponseForTag(tag: String): ImapResponse {
        while (true) {
            val line = reader?.readLine() ?: throw ImapConnectionException("Connection closed")
            
            if (config.debugMode) {
                logger.debug("<< $line")
            }
            metrics.recordBytesReceived(line.length.toLong() + 2)
            metrics.recordActivity()
            
            // Handle untagged responses
            if (line.startsWith("*")) continue
            
            // Handle continuation
            if (line.startsWith("+")) {
                return ImapResponse(
                    type = ImapResponseType.CONTINUATION,
                    message = line.substring(1).trim()
                )
            }
            
            // Check tag
            val lineTag = line.substringBefore(" ")
            if (lineTag != tag) continue
            
            // Parse response
            return when {
                line.contains("OK") -> {
                    val code = extractResponseCode(line)
                    ImapResponse(
                        tag = tag,
                        type = ImapResponseType.OK,
                        message = line.substringAfter("OK ").trim(),
                        responseCode = code,
                        responseData = parseResponseCode(code ?: "")
                    )
                }
                line.contains("NO") -> ImapResponse(
                    tag = tag,
                    type = ImapResponseType.NO,
                    message = line.substringAfter("NO ").trim()
                )
                line.contains("BAD") -> ImapResponse(
                    tag = tag,
                    type = ImapResponseType.BAD,
                    message = line.substringAfter("BAD ").trim()
                )
                else -> ImapResponse(
                    tag = tag,
                    type = ImapResponseType.OK,
                    message = line
                )
            }
        }
    }
    
    private suspend fun readResponseInternal(): ImapResponse {
        val line = reader?.readLine() ?: throw ImapConnectionException("Connection closed")
        
        if (config.debugMode) {
            logger.debug("<< $line")
        }
        
        return when {
            line.startsWith("+") -> ImapResponse(
                type = ImapResponseType.CONTINUATION,
                message = line.substring(1).trim()
            )
            line.startsWith("* OK") -> ImapResponse(
                type = ImapResponseType.OK,
                message = line.substringAfter("OK ").trim()
            )
            line.startsWith("* BYE") -> ImapResponse(
                type = ImapResponseType.BYE,
                message = line.substringAfter("BYE ").trim()
            )
            line.startsWith("* PREAUTH") -> ImapResponse(
                type = ImapResponseType.PREAUTH,
                message = line.substringAfter("PREAUTH ").trim()
            )
            else -> ImapResponse(
                type = ImapResponseType.OK,
                message = line
            )
        }
    }
    
    private fun extractResponseCode(line: String): String? {
        val match = Regex("\\[([^\\]]+)\\]").find(line)
        return match?.groupValues?.get(1)
    }
    
    private fun parseResponseCode(code: String): Map<String, String> {
        val data = mutableMapOf<String, String>()
        code.split(" ").forEach { part ->
            val (key, value) = part.split("=", limit = 2)
            data[key] = value
        }
        return data
    }
    
    // ========================================================================
    // UTILITY METHODS
    // ========================================================================
    
    private fun quoteString(str: String): String {
        return "\"${str.replace("\\", "\\\\").replace("\"", "\\\"")}\""
    }
    
    private fun parseQuotedStrings(data: String): List<String> {
        val result = mutableListOf<String>()
        val regex = Regex("\"([^\"]*)\"|(\\S+)")
        regex.findAll(data).forEach { match ->
            result.add(match.groupValues[1].ifEmpty { match.groupValues[2] })
        }
        return result
    }
    
    private fun extractNumber(line: String): Int {
        val match = Regex("\\d+").find(line)
        return match?.value?.toIntOrNull() ?: 0
    }
    
    private fun requireAuth() {
        if (state.get() !in setOf(ImapState.AUTHENTICATED, ImapState.SELECTED)) {
            throw ImapStateException(
                "Authentication required",
                state.get(),
                ImapState.AUTHENTICATED
            )
        }
    }
    
    private fun requireSelected() {
        if (state.get() != ImapState.SELECTED) {
            throw ImapStateException(
                "Mailbox not selected",
                state.get(),
                ImapState.SELECTED
            )
        }
    }
    
    // ========================================================================
    // CONNECTION EVENT CALLBACK TYPE
    // ========================================================================
    
    typealias ConnectionEventCallback = (ConnectionEvent) -> Unit
}

