@Composable
fun HomeScreen(
    viewModel: HomeViewModel,
    onAddToken: (UiToken) -> Unit = {},
    onOpenSettings: () -> Unit = {},
    modifier: Modifier = Modifier,
    clock: ClockProvider = SystemClockProvider()
) {
    val uiState by viewModel.uiState.collectAsState()
    val scaffoldState = rememberScaffoldState()
    val coroutineScope = rememberCoroutineScope()
    val context = LocalContext.current
    val clipboardManager = LocalClipboardManager.current

    // snackbar handling
    LaunchedEffect(uiState.snackbarMessage) {
        uiState.snackbarMessage?.let { msg ->
            scaffoldState.snackbarHostState.showSnackbar(msg)
            // clear message after showing
            // (In a real app, ViewModel should clear it; here we rely on ephemeral UI)
        }
    }

    HomeSurfaceContainer {
        Scaffold(
            scaffoldState = scaffoldState,
            topBar = {
                HomeTopBar(onOpenSettings = onOpenSettings, onRefresh = { viewModel.onEvent(HomeUiEvent.Refresh) })
            },
            floatingActionButton = {
                FloatingActionButton(onClick = { /* open add sheet */ }) {
                    Icon(Icons.Default.Add, contentDescription = "Add token")
                }
            },
            backgroundColor = HomeBackground,
            modifier = modifier.fillMaxSize()
        ) { padding ->
            Column(modifier = Modifier.fillMaxSize().padding(padding)) {
                // Header with last refresh and lock/unlock
                HomeHeader(
                    lastRefreshEpochMs = uiState.lastRefreshEpochMs,
                    isVaultUnlocked = uiState.isVaultUnlocked,
                    onLock = { viewModel.onEvent(HomeUiEvent.LockVault) },
                    onUnlock = { viewModel.onEvent(HomeUiEvent.UnlockVault) }
                )
                Spacer(modifier = Modifier.height(8.dp))
                // Token list
                TokenList(
                    tokens = uiState.tokens,
                    isVaultUnlocked = uiState.isVaultUnlocked,
                    onCopy = { token ->
                        // copy current TOTP code to clipboard
                        val code = if (token.secretBase32 == "••••••") null else TotpManager.nowFromBase32(token.secretBase32, token.digits, token.period, "HmacSHA1")
                        if (code != null) {
                            clipboardManager.setText(AnnotatedString(code))
                            coroutineScope.launch { scaffoldState.snackbarHostState.showSnackbar("Code copied") }
                        } else {
                            coroutineScope.launch { scaffoldState.snackbarHostState.showSnackbar("Vault locked. Unlock to copy codes.") }
                        }
                    },
                    onDelete = { tokenId ->
                        viewModel.onEvent(HomeUiEvent.DeleteToken(tokenId))
                    },
                    onRefresh = { viewModel.onEvent(HomeUiEvent.Refresh) },
                    clock = clock
                )
            }
        }
    }
}

