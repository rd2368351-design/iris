@Composable
private fun HomeHeader(
    lastRefreshEpochMs: Long,
    isVaultUnlocked: Boolean,
    onLock: () -> Unit,
    onUnlock: () -> Unit
) {
    val formatter = remember {
        DateTimeFormatter.ofPattern("yyyy-MM-dd HH:mm:ss").withZone(ZoneId.systemDefault())
    }
    val lastRefreshText = if (lastRefreshEpochMs <= 0L) "Never" else formatter.format(Instant.ofEpochMilli(lastRefreshEpochMs))
    Row(
        modifier = Modifier
            .fillMaxWidth()
            .padding(horizontal = 16.dp),
        verticalAlignment = Alignment.CenterVertically
    ) {
        Column(modifier = Modifier.weight(1f)) {
            Text("Last refresh: $lastRefreshText", color = HomeOnSurface.copy(alpha = 0.8f), style = MaterialTheme.typography.caption)
            Text(if (isVaultUnlocked) "Vault: Unlocked" else "Vault: Locked", color = if (isVaultUnlocked) HomeSecondary else HomeError, style = MaterialTheme.typography.body2)
        }
        if (isVaultUnlocked) {
            Button(onClick = onLock, colors = ButtonDefaults.buttonColors(backgroundColor = HomePrimary)) {
                Text("Lock", color = HomeOnSurface)
            }
        } else {
            Button(onClick = onUnlock, colors = ButtonDefaults.buttonColors(backgroundColor = HomePrimary)) {
                Text("Unlock", color = HomeOnSurface)
            }
        }
    }
}

