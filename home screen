            OutlinedTextField(value = period.value, onValueChange = { period.value = it }, label = { Text("Period") }, modifier = Modifier.weight(1f))
        }
        Spacer(modifier = Modifier.height(12.dp))
        Row(horizontalArrangement = Arrangement.End, modifier = Modifier.fillMaxWidth()) {
            TextButton(onClick = onClose) { Text("Cancel") }
            Spacer(modifier = Modifier.width(8.dp))
            Button(onClick = {
                val token = UiToken(
                    id = System.currentTimeMillis(),
                    label = label.value,
                    issuer = issuer.value.ifBlank { null },
                    secretBase32 = secret.value,
                    algorithm = "SHA1",
                    digits = digits.value.toIntOrNull() ?: 6,
                    period = period.value.toIntOrNull() ?: 30
                )
                onAdd(token)
                onClose()
            }) {
                Text("Add")
            }
        }
    }
}

