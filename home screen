/**
 * A utility to format seconds into mm:ss
 */
private fun formatSecondsToMmSs(seconds: Int): String {
    val s = max(0, seconds)
    val mm = s / 60
    val ss = s % 60
    return "%02d:%02d".format(mm, ss)
}

/**
 * Deterministic random color generator for token avatars
 */
private fun avatarColorForLabel(label: String): Color {
    val hash = label.hashCode()
    val r = (hash shr 16 and 0xFF) / 255f
    val g = (hash shr 8 and 0xFF) / 255f
    val b = (hash and 0xFF) / 255f
    return Color(red = r, green = g, blue = b)
}

