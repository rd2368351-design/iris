interface ClockProvider {
    fun nowSeconds(): Long
}

class SystemClockProvider : ClockProvider {
    override fun nowSeconds(): Long = System.currentTimeMillis() / 1000L
}

class FixedClockProvider(private val fixedSeconds: Long) : ClockProvider {
    override fun nowSeconds(): Long = fixedSeconds
}

/* ============================
   UI State and Events
   ============================ */

sealed class HomeUiEvent {
    object Refresh : HomeUiEvent()
    data class CopyToClipboard(val token: UiToken) : HomeUiEvent()
    data class DeleteToken(val tokenId: Long) : HomeUiEvent()
    data class AddToken(val token: UiToken) : HomeUiEvent()
    data class ShowError(val message: String) : HomeUiEvent()
    object LockVault : HomeUiEvent()
    object UnlockVault : HomeUiEvent()
}

data class HomeUiState(
    val tokens: List<UiToken> = emptyList(),
    val isLoading: Boolean = false,
    val lastRefreshEpochMs: Long = 0L,
    val snackbarMessage: String? = null,
    val isVaultUnlocked: Boolean = false
)

/* ============================
   ViewModel
   ============================ */

class HomeViewModel(
    private val context: Context,
    private val repo: TokenRepository,
    private val vaultManager: VaultManager,
    private val clock: ClockProvider = SystemClockProvider()
) : ViewModel() {

    private val _uiState = MutableStateFlow(HomeUiState())
    val uiState: StateFlow<HomeUiState> = _uiState

    private val _events = MutableSharedFlow<HomeUiEvent>(extraBufferCapacity = 8)

    // Expose a coroutine scope tied to the ViewModel
    private val vmScope = viewModelScope

    // Local in-memory cache for decrypted secrets (avoid storing plaintext long-term)
    private val decryptedCache = mutableMapOf<Long, String>()

    // Session id for unlocked vault (if any)
    private var sessionId: String? = null

    init {
        // initial load
        vmScope.launch {
            loadTokens()
        }
    }

    private suspend fun loadTokens() {
        _uiState.value = _uiState.value.copy(isLoading = true)
        try {
            // Attempt to load derived key from wrapped vault; if not available, show locked state
            val derived = try {
                vaultManager.loadDerivedKeyFromWrapped()
            } catch (e: Exception) {
                null
            }

            if (derived == null) {
                // Vault locked; show tokens masked
                val entities = repo.listTokens(ByteArray(32)) // pass dummy key to get metadata only
                val uiTokens = entities.map { e ->
                    UiToken(e.id, e.label, e.issuer, "••••••", e.algorithm, e.digits, e.period)
                }
                _uiState.value = HomeUiState(tokens = uiTokens, isLoading = false, lastRefreshEpochMs = System.currentTimeMillis(), isVaultUnlocked = false)
                return
            } else {
                // If derived key exists, decrypt tokens
                val entities = repo.listTokens(derived)
                val uiTokens = entities.map { e ->
                    UiToken(e.id, e.label, e.issuer, e.secretBase32, e.algorithm, e.digits, e.period)
                }
                // wipe derived key after use
                wipeByteArray(derived)
                _uiState.value = HomeUiState(tokens = uiTokens, isLoading = false, lastRefreshEpochMs = System.currentTimeMillis(), isVaultUnlocked = true)
            }
        } catch (e: Exception) {
            _uiState.value = _uiState.value.copy(isLoading = false, snackbarMessage = "Failed to load tokens: ${e.message}")
        }
    }

    fun onEvent(event: HomeUiEvent) {
        when (event) {
            is HomeUiEvent.Refresh -> {
                vmScope.launch { refresh() }
            }
            is HomeUiEvent.CopyToClipboard -> {
                vmScope.launch { copyTokenToClipboard(event.token) }
            }
            is HomeUiEvent.DeleteToken -> {
                vmScope.launch { deleteToken(event.tokenId) }
            }
            is HomeUiEvent.AddToken -> {
                vmScope.launch { addToken(event.token) }
            }
            is HomeUiEvent.ShowError -> {
                _uiState.value = _uiState.value.copy(snackbarMessage = event.message)
            }
            HomeUiEvent.LockVault -> {
                lockVault()
            }
            HomeUiEvent.UnlockVault -> {
                vmScope.launch { unlockVaultInteractive() }
            }
        }
    }

    private suspend fun refresh() {
        _uiState.value = _uiState.value.copy(isLoading = true)
        try {
            // If vault unlocked, reload decrypted tokens
            val derived = try {
                vaultManager.loadDerivedKeyFromWrapped()
            } catch (e: Exception) {
                null
            }
            if (derived != null) {
                val entities = repo.listTokens(derived)
                val uiTokens = entities.map { e ->
                    UiToken(e.id, e.label, e.issuer, e.secretBase32, e.algorithm, e.digits, e.period)
                }
                wipeByteArray(derived)
                _uiState.value = _uiState.value.copy(tokens = uiTokens, isLoading = false, lastRefreshEpochMs = System.currentTimeMillis(), isVaultUnlocked = true)
            } else {
                // vault locked: show masked tokens
                val entities = repo.listTokens(ByteArray(32))
                val uiTokens = entities.map { e ->
                    UiToken(e.id, e.label, e.issuer, "••••••", e.algorithm, e.digits, e.period)
                }
                _uiState.value = _uiState.value.copy(tokens = uiTokens, isLoading = false, lastRefreshEpochMs = System.currentTimeMillis(), isVaultUnlocked = false)
            }
        } catch (e: Exception) {
            _uiState.value = _uiState.value.copy(isLoading = false, snackbarMessage = "Refresh failed: ${e.message}")
        }
    }

    private suspend fun copyTokenToClipboard(token: UiToken) {
        // For security, copy only the current TOTP code, not the secret
        try {
            val now = clock.nowSeconds()
            val code = if (token.secretBase32 == "••••••") {
                // cannot copy masked secret
                null
            } else {
                TotpManager.nowFromBase32(token.secretBase32, token.digits, token.period, "HmacSHA1")
            }
            if (code == null) {
                _uiState.value = _uiState.value.copy(snackbarMessage = "Vault locked. Unlock to copy codes.")
                return
            }
            // Use platform clipboard via event; actual clipboard copy happens in UI layer
            _events.tryEmit(HomeUiEvent.CopyToClipboard(token))
            _uiState.value = _uiState.value.copy(snackbarMessage = "Code copied to clipboard")
        } catch (e: Exception) {
            _uiState.value = _uiState.value.copy(snackbarMessage = "Copy failed: ${e.message}")
        }
    }

    private suspend fun deleteToken(tokenId: Long) {
        try {
            repo.deleteTokenById(tokenId)
            // optimistic UI update
            _uiState.value = _uiState.value.copy(tokens = _uiState.value.tokens.filterNot { it.id == tokenId }, snackbarMessage = "Token deleted")
        } catch (e: Exception) {
            _uiState.value = _uiState.value.copy(snackbarMessage = "Delete failed: ${e.message}")
        }
    }

    private suspend fun addToken(token: UiToken) {
        try {
            // For adding, require derived key
            val derived = vaultManager.loadDerivedKeyFromWrapped()
            val id = repo.addToken(token.label, token.issuer, token.secretBase32, token.algorithm, token.digits, token.period, derived)
            wipeByteArray(derived)
            // reload
            refresh()
            _uiState.value = _uiState.value.copy(snackbarMessage = "Token added")
        } catch (e: Exception) {
            _uiState.value = _uiState.value.copy(snackbarMessage = "Add failed: ${e.message}")
        }
    }

    private fun lockVault() {
        // Clear session cache and mark locked
        vaultManager.wipeAllVaultData()
        _uiState.value = _uiState.value.copy(isVaultUnlocked = false, snackbarMessage = "Vault locked")
    }

    private suspend fun unlockVaultInteractive() {
        // This is a placeholder for biometric/passphrase flow; in real app, show UI to get passphrase
        // For demo, attempt to load derived key; if present, mark unlocked
        try {
            val derived = vaultManager.loadDerivedKeyFromWrapped()
            wipeByteArray(derived)
            _uiState.value = _uiState.value.copy(isVaultUnlocked = true, snackbarMessage = "Vault unlocked")
            refresh()
        } catch (e: Exception) {
            _uiState.value = _uiState.value.copy(snackbarMessage = "Unlock failed: ${e.message}")
        }
    }

    /**
     * Expose events flow for UI to react (clipboard copy, etc.)
     */
    fun eventsFlow(): MutableSharedFlow<HomeUiEvent> = _events

    override fun onCleared() {
        super.onCleared()
        // wipe caches
        decryptedCache.clear()
    }

    // Utility to wipe byte arrays
    private fun wipeByteArray(b: ByteArray?) {
        if (b == null) return
        for (i in b.indices) b[i] = 0
    }
}

