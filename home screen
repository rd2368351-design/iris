@Composable
private fun TokenRow(
    token: UiToken,
    isVaultUnlocked: Boolean,
    onCopy: () -> Unit,
    onDelete: () -> Unit,
    clock: ClockProvider
) {
    val period = token.period.toLong()
    val now = clock.nowSeconds()
    val secondsIntoPeriod = now % period
    val secondsLeft = (period - secondsIntoPeriod).toInt()
    val progress = (secondsLeft.toFloat() / period.toFloat())

    // Animated progress for ring
    val animatedProgress by animateFloatAsState(
        targetValue = progress,
        animationSpec = tween(durationMillis = 300, easing = LinearEasing)
    )

    val code = remember(token, isVaultUnlocked, now) {
        if (!isVaultUnlocked || token.secretBase32 == "••••••") {
            "••••••"
        } else {
            try {
                TotpManager.nowFromBase32(token.secretBase32, token.digits, token.period, "HmacSHA1")
            } catch (e: Exception) {
                "ERR"
            }
        }
    }

    val backgroundBrush = Brush.horizontalGradient(listOf(HomeSurface, HomeSurface.copy(alpha = 0.95f)))
    Card(
        modifier = Modifier
            .fillMaxWidth()
            .padding(horizontal = 12.dp, vertical = 8.dp)
            .combinedClickable(
                onClick = { /* open detail */ },
                onLongClick = { /* show context menu */ }
            ),
        backgroundColor = HomeSurface,
        elevation = 4.dp,
        shape = RoundedCornerShape(12.dp)
    ) {
        Row(modifier = Modifier
            .fillMaxWidth()
            .padding(12.dp),
            verticalAlignment = Alignment.CenterVertically
        ) {
            // Progress ring and code
            Box(modifier = Modifier.size(64.dp), contentAlignment = Alignment.Center) {
                CircularProgressRing(progress = animatedProgress, size = 64.dp, strokeWidth = 6.dp)
                Column(horizontalAlignment = Alignment.CenterHorizontally) {
                    Text(code, color = HomeOnSurface, fontWeight = FontWeight.Bold)
                    Text(secondsLeft.toString(), color = HomeOnSurface.copy(alpha = 0.7f), style = MaterialTheme.typography.caption)
                }
            }
            Spacer(modifier = Modifier.width(12.dp))
            Column(modifier = Modifier.weight(1f)) {
                Text(token.label, color = HomeOnSurface, fontWeight = FontWeight.SemiBold, maxLines = 1, overflow = TextOverflow.Ellipsis)
                Text(token.issuer ?: "", color = HomeOnSurface.copy(alpha = 0.7f), style = MaterialTheme.typography.body2, maxLines = 1, overflow = TextOverflow.Ellipsis)
            }
            IconButton(onClick = onCopy) {
                Icon(Icons.Default.ContentCopy, contentDescription = "Copy code", tint = HomeOnSurface)
            }
            IconButton(onClick = onDelete) {
                Icon(Icons.Default.Delete, contentDescription = "Delete token", tint = HomeError)
            }
        }
    }
}

/* ============================
   Circular Progress Ring
   ============================ */

@Composable
private fun CircularProgressRing(progress: Float, size: Dp, strokeWidth: Dp) {
    // Draw a circular progress ring with background track and animated progress
    val stroke = with(LocalDensity.current) { strokeWidth.toPx() }
    val animated = remember { Animatable(progress) }
    LaunchedEffect(progress) {
        animated.animateTo(progress, animationSpec = tween(durationMillis = 300, easing = LinearEasing))
    }
    Canvas(modifier = Modifier.size(size)) {
        val diameter = size.toPx()
        val radius = diameter / 2f
        val center = androidx.compose.ui.geometry.Offset(radius, radius)
        // background track
        drawCircle(color = HomeSurface.copy(alpha = 0.2f), radius = radius - stroke / 2f, style = androidx.compose.ui.graphics.drawscope.Stroke(width = stroke))
        // progress arc
        val sweep = 360f * animated.value
        drawArc(
            brush = Brush.sweepGradient(listOf(HomePrimary, HomeSecondary)),
            startAngle = -90f,
            sweepAngle = sweep,
            useCenter = false,
            style = androidx.compose.ui.graphics.drawscope.Stroke(width = stroke),
            topLeft = androidx.compose.ui.geometry.Offset(stroke / 2f, stroke / 2f),
            size = androidx.compose.ui.geometry.Size(diameter - stroke, diameter - stroke)
        )
    }
}

