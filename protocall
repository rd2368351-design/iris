    suspend fun startIdle(): Result<Unit> = withContext(Dispatchers.IO) {
        try {
            requireSelectedState()
            
            if (!serverCapabilities.idle) {
                return@withContext Result.failure(
                    ImapException("Server doesn't support IDLE")
                )
            }
            
            val tag = nextTag()
            sendRaw("$tag IDLE")
            
            // Wait for continuation
            val response = readResponse()
            if (response.type != ImapResponseType.CONTINUATION) {
                return@withContext Result.failure(
                    ImapException("IDLE initialization failed")
                )
            }
            
            // Start monitoring for updates
            idleJob = CoroutineScope(Dispatchers.IO).launch {
                try {
                    while (isActive) {
                        val update = reader?.readLine() ?: break
                        
                        if (update.startsWith("*")) {
                            val parsedResponse = parseUnsolicitedResponse(update)
                            idleCallbacks.forEach { callback ->
                                callback(parsedResponse)
                            }
                        }
                    }
                } catch (e: Exception) {
                    logger.error("IDLE monitoring error", e)
                }
            }
            
            Result.success(Unit)
            
        } catch (e: Exception) {
            Result.failure(e)
        }
    }
    
    suspend fun stopIdle(): Result<Unit> = withContext(Dispatchers.IO) {
        try {
            idleJob?.cancel()
            idleJob = null
            
            sendRaw("DONE")
            val response = readResponse()
            
            if (response.type == ImapResponseType.OK) {
                idleCallbacks.clear()
                Result.success(Unit)
            } else {
                Result.failure(ImapException("Failed to stop IDLE"))
            }
            
        } catch (e: Exception) {
            Result.failure(e)
        }
    }
    
    fun addIdleCallback(callback: (ImapResponse) -> Unit) {
        idleCallbacks.add(callback)
    }
    
    fun removeIdleCallback(callback: (ImapResponse) -> Unit) {
        idleCallbacks.remove(callback)
    }
    
    private fun parseUnsolicitedResponse(line: String): ImapResponse {
        return when {
            line.contains("EXISTS") -> {
                val count = extractFirstNumber(line)
                ImapResponse(
                    tag = null,
                    type = ImapResponseType.OK,
                    message = "New messages: $count",
                    data = mapOf("exists" to count)
                )
            }
            line.contains("EXPUNGE") -> {
                val seq = extractFirstNumber(line)
                ImapResponse(
                    tag = null,
                    type = ImapResponseType.OK,
                    message = "Message expunged: $seq",
                    data = mapOf("expunge" to seq)
                )
            }
            line.contains("FETCH") -> {
                ImapResponse(
                    tag = null,
                    type = ImapResponseType.OK,
                    message = "Fetch update",
                    data = line
                )
            }
            else -> {
                ImapResponse(
                    tag = null,
                    type = ImapResponseType.OK,
                    message = line
                )
            }
        }
    }
    
