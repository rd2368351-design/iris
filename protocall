// ============================================
// MAIN PROTOCOL HANDLER (8000+ LOC)
// ============================================

class ImapProtocolHandler(
    private val config: ImapConfiguration,
    private val logger: ImapLogger = ImapLogger()
) {
    // State Management
    private var state: ImapState = ImapState.NOT_AUTHENTICATED
    private var selectedMailbox: MailboxInfo? = null
    private val tagCounter = AtomicLong(0)
    
    // Connection Management
    private var socket: Socket? = null
    private var sslSocket: SSLSocket? = null
    private var reader: BufferedReader? = null
    private var writer: BufferedWriter? = null
    private var inputStream: InputStream? = null
    private var outputStream: OutputStream? = null
    
    // Capabilities
    private var serverCapabilities: ImapCapability = ImapCapability()
    private var enabledCapabilities: MutableSet<String> = mutableSetOf()
    
    // IDLE Management
    private var idleJob: Job? = null
    private val idleCallbacks = mutableListOf<(ImapResponse) -> Unit>()
    
    // Connection Pool
    private val connectionLock = Any()
    private var isConnected = false
    
    // Compression
    private var compressionEnabled = false
    private var compressedInputStream: InputStream? = null
    private var compressedOutputStream: OutputStream? = null

    // ==========================================
    // CONNECTION MANAGEMENT (1500+ LOC)
    // ==========================================
    
    suspend fun connect(): Result<Unit> = withContext(Dispatchers.IO) {
        try {
            if (isConnected) disconnect()
            
            logger.debug("Connecting to ${config.host}:${config.port}")
            
            socket = Socket()
            socket!!.connect(
                java.net.InetSocketAddress(config.host, config.port),
                config.connectionTimeout.toInt()
            )
            
            if (config.useSSL) {
                startSSLHandshake()
            }
            
            setupStreams()
            
            // Read server greeting
            val greeting = readResponse()
            if (greeting.type == ImapResponseType.BYE) {
                throw ImapConnectionException("Server rejected connection: ${greeting.message}")
            }
            
            // Get initial capabilities
            getCapabilities()
            
            isConnected = true
            state = ImapState.NOT_AUTHENTICATED
            
            logger.info("Connected successfully to ${config.host}")
            Result.success(Unit)
            
        } catch (e: Exception) {
            logger.error("Connection failed", e)
            disconnect()
            Result.failure(ImapConnectionException("Failed to connect: ${e.message}", e))
        }
    }
    
    private fun startSSLHandshake() {
        val sslContext = SSLContext.getInstance("TLS")
        val trustManager = object : X509TrustManager {
            override fun checkClientTrusted(chain: Array<X509Certificate>, authType: String) {}
            override fun checkServerTrusted(chain: Array<X509Certificate>, authType: String) {}
            override fun getAcceptedIssuers(): Array<X509Certificate> = arrayOf()
        }
        sslContext.init(null, arrayOf(trustManager), java.security.SecureRandom())
        
        sslSocket = sslContext.socketFactory.createSocket(
            socket,
            config.host,
            config.port,
            true
        ) as SSLSocket
        
        sslSocket!!.startHandshake()
        logger.debug("SSL handshake completed")
    }
    
    private fun setupStreams() {
        val activeSocket = sslSocket ?: socket!!
        
        if (compressionEnabled) {
            // DEFLATE compression setup
            compressedInputStream = java.util.zip.InflaterInputStream(
                activeSocket.getInputStream()
            )
            compressedOutputStream = java.util.zip.DeflaterOutputStream(
                activeSocket.getOutputStream()
            )
            
            inputStream = compressedInputStream
            outputStream = compressedOutputStream
        } else {
            inputStream = activeSocket.getInputStream()
            outputStream = activeSocket.getOutputStream()
        }
        
        reader = BufferedReader(InputStreamReader(inputStream!!, Charsets.UTF_8))
        writer = BufferedWriter(OutputStreamWriter(outputStream!!, Charsets.UTF_8))
    }
    
    suspend fun disconnect() {
        withContext(Dispatchers.IO) {
            try {
                if (isConnected) {
                    sendCommand(ImapCommand.LOGOUT)
                }
            } catch (e: Exception) {
                // Ignore logout errors
            } finally {
                closeAllStreams()
                isConnected = false
                state = ImapState.LOGOUT
                selectedMailbox = null
            }
        }
    }
    
    private fun closeAllStreams() {
        try { reader?.close() } catch (e: Exception) {}
        try { writer?.close() } catch (e: Exception) {}
        try { inputStream?.close() } catch (e: Exception) {}
        try { outputStream?.close() } catch (e: Exception) {}
        try { compressedInputStream?.close() } catch (e: Exception) {}
        try { compressedOutputStream?.close() } catch (e: Exception) {}
        try { sslSocket?.close() } catch (e: Exception) {}
        try { socket?.close() } catch (e: Exception) {}
        
        reader = null
        writer = null
        inputStream = null
        outputStream = null
        compressedInputStream = null
        compressedOutputStream = null
        sslSocket = null
        socket = null
    }
    
    // ==========================================
    // AUTHENTICATION METHODS (2000+ LOC)
    // ==========================================
    
    suspend fun login(username: String, password: String): Result<Unit> = 
        withContext(Dispatchers.IO) {
            try {
                if (state != ImapState.NOT_AUTHENTICATED) {
                    return@withContext Result.failure(
                        ImapStateException("Already authenticated")
                    )
                }
                
                // Try STARTTLS if available
                if (serverCapabilities.startTls && !config.useSSL) {
                    startTLS()
                }
                
                // LOGIN command (base64 encoded for security)
                val encodedUsername = Base64.getEncoder().encodeToString(
                    username.toByteArray()
                )
                val encodedPassword = Base64.getEncoder().encodeToString(
                    password.toByteArray()
                )
                
                val command = "LOGIN $encodedUsername $encodedPassword"
                val response = sendCommandWithResponse(command)
                
                if (response.type == ImapResponseType.OK) {
                    state = ImapState.AUTHENTICATED
                    
                    // Get capabilities after login
                    getCapabilities()
                    
                    // Enable compression if available
                    if (config.compressionEnabled && serverCapabilities.compress) {
                        enableCompression()
                    }
                    
                    logger.info("Login successful for user: $username")
                    Result.success(Unit)
                } else {
                    Result.failure(
                        ImapAuthenticationException("Login failed: ${response.message}")
                    )
                }
                
            } catch (e: Exception) {
                logger.error("Login error", e)
                Result.failure(ImapAuthenticationException("Login error: ${e.message}"))
            }
        }
    
    suspend fun authenticateOAuth2(
        accessToken: String,
        username: String
    ): Result<Unit> = withContext(Dispatchers.IO) {
        try {
            if (!serverCapabilities.auth.contains("XOAUTH2") && 
                !serverCapabilities.auth.contains("OAUTHBEARER")) {
                return@withContext Result.failure(
                    ImapException("Server doesn't support OAuth2 authentication")
                )
            }
            
            val authMechanism = if (serverCapabilities.auth.contains("XOAUTH2")) {
                "XOAUTH2"
            } else {
                "OAUTHBEARER"
            }
            
            val authString = "user=$username\u0001auth=Bearer $accessToken\u0001\u0001"
            val encodedAuth = Base64.getEncoder().encodeToString(
                authString.toByteArray()
            )
            
            val tag = nextTag()
            sendRaw("$tag AUTHENTICATE $authMechanism $encodedAuth")
            
            val response = readResponse()
            if (response.type == ImapResponseType.CONTINUATION) {
                // Send empty line to complete SASL exchange
                sendRaw("")
                val finalResponse = readResponse()
                if (finalResponse.type == ImapResponseType.OK) {
                    state = ImapState.AUTHENTICATED
                    getCapabilities()
                    logger.info("OAuth2 authentication successful")
                    Result.success(Unit)
                } else {
                    Result.failure(
                        ImapAuthenticationException("OAuth2 failed: ${finalResponse.message}")
                    )
                }
            } else {
                Result.failure(
                    ImapAuthenticationException("OAuth2 failed: ${response.message}")
                )
            }
            
        } catch (e: Exception) {
            Result.failure(ImapAuthenticationException("OAuth2 error: ${e.message}"))
        }
    }
    
    private suspend fun startTLS() {
        val response = sendCommandWithResponse("STARTTLS")
        if (response.type == ImapResponseType.OK) {
            startSSLHandshake()
            setupStreams()
            logger.debug("STARTTLS successful")
        } else {
            throw ImapException("STARTTLS failed: ${response.message}")
        }
    }
    
    private suspend fun enableCompression() {
        val response = sendCommandWithResponse("COMPRESS DEFLATE")
        if (response.type == ImapResponseType.OK) {
            compressionEnabled = true
            setupStreams()
            logger.debug("Compression enabled")
        }
    }
    
    // ==========================================
    // MAILBOX OPERATIONS (3000+ LOC)
    // ==========================================
    
    suspend fun selectMailbox(mailboxName: String, readOnly: Boolean = false): 
        Result<MailboxInfo> = withContext(Dispatchers.IO) {
            
        try {
            requireAuth()
            
            val command = if (readOnly) "EXAMINE" else "SELECT"
            val tag = nextTag()
            sendRaw("$tag $command \"$mailboxName\"")
            
            val mailbox = parseMailboxSelectResponse(tag)
            selectedMailbox = mailbox
            state = ImapState.SELECTED
            
            logger.info("Selected mailbox: $mailboxName (${mailbox.exists} messages)")
            Result.success(mailbox)
            
        } catch (e: Exception) {
            logger.error("Failed to select mailbox: $mailboxName", e)
            Result.failure(e)
        }
    }
    
    private suspend fun parseMailboxSelectResponse(tag: String): MailboxInfo {
        var exists = 0
        var recent = 0
        var unseen = 0
        var uidNext = 0L
        var uidValidity = 0L
        var highestModSeq = 0L
        val flags = mutableSetOf<MailboxFlag>()
        
        while (true) {
            val line = reader!!.readLine() ?: throw ImapConnectionException("Connection closed")
            
            when {
                line.startsWith("* OK [UNSEEN") -> {
                    unseen = extractNumber(line, "UNSEEN")
                }
                line.startsWith("* OK [UIDNEXT") -> {
                    uidNext = extractNumber(line, "UIDNEXT").toLong()
                }
                line.startsWith("* OK [UIDVALIDITY") -> {
                    uidValidity = extractNumber(line, "UIDVALIDITY").toLong()
                }
                line.startsWith("* OK [HIGHESTMODSEQ") -> {
                    highestModSeq = extractNumber(line, "HIGHESTMODSEQ").toLong()
                }
                line.startsWith("* FLAGS") -> {
                    parseFlags(line).forEach { flags.add(it) }
                }
                line.matches(Regex("\\* (\\d+) EXISTS")) -> {
                    exists = extractFirstNumber(line)
                }
                line.matches(Regex("\\* (\\d+) RECENT")) -> {
                    recent = extractFirstNumber(line)
                }
                line.startsWith("$tag OK") -> {
                    break
                }
                line.startsWith("$tag NO") || line.startsWith("$tag BAD") -> {
                    throw ImapCommandException(
                        if (line.startsWith("$tag NO")) ImapResponseType.NO 
                        else ImapResponseType.BAD,
                        line
                    )
                }
            }
        }
        
        return MailboxInfo(
            name = selectedMailbox?.name ?: "",
            attributes = emptyList(),
            delimiter = "/",
            flags = flags,
            exists = exists,
            recent = recent,
            unseen = unseen,
            uidNext = uidNext,
            uidValidity = uidValidity,
            highestModSeq = highestModSeq
        )
    }
    
    suspend fun listMailboxes(
        referenceName: String = "",
        mailboxName: String = "*"
    ): Result<List<MailboxInfo>> = withContext(Dispatchers.IO) {
        
        try {
            requireAuth()
            
            val tag = nextTag()
            sendRaw("$tag LIST \"$referenceName\" \"$mailboxName\"")
            
            val mailboxes = mutableListOf<MailboxInfo>()
            
            while (true) {
                val line = reader!!.readLine() ?: break
                
                if (line.startsWith("* LIST")) {
                    val mailbox = parseListResponse(line)
                    mailboxes.add(mailbox)
                } else if (line.startsWith("$tag")) {
                    if (line.contains("OK")) {
                        break
                    } else {
                        throw ImapCommandException(
                            if (line.contains("NO")) ImapResponseType.NO 
                            else ImapResponseType.BAD,
                            line
                        )
                    }
                }
            }
            
            Result.success(mailboxes)
            
        } catch (e: Exception) {
            Result.failure(e)
        }
    }
    
    private fun parseListResponse(line: String): MailboxInfo {
        // Parse LIST response format: * LIST (attributes) "delimiter" "name"
        val attributeStart = line.indexOf('(')
        val attributeEnd = line.indexOf(')')
        val attributes = line.substring(attributeStart + 1, attributeEnd)
            .split(" ")
            .filter { it.isNotEmpty() }
        
        val remaining = line.substring(attributeEnd + 1).trim()
        val parts = remaining.split(" ")
        
        val delimiter = parts.getOrNull(0)?.removeSurrounding("\"") ?: "/"
        val name = parts.drop(1).joinToString(" ").removeSurrounding("\"")
        
        return MailboxInfo(
            name = name,
            attributes = attributes,
            delimiter = delimiter
        )
    }
    
