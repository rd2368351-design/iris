enum class ImapState {
    NOT_AUTHENTICATED,
    AUTHENTICATED,
    SELECTED,
    LOGOUT
}

enum class ImapCommand(
    val command: String,
    val requiresAuth: Boolean = true,
    val requiresSelected: Boolean = false
) {
    // Non-Authenticated State
    CAPABILITY("CAPABILITY", false),
    NOOP("NOOP", false),
    LOGOUT("LOGOUT", false),
    STARTTLS("STARTTLS", false),
    AUTHENTICATE("AUTHENTICATE", false),
    LOGIN("LOGIN", false),
    
    // Authenticated State
    SELECT("SELECT", true),
    EXAMINE("EXAMINE", true),
    CREATE("CREATE", true),
    DELETE("DELETE", true),
    RENAME("RENAME", true),
    SUBSCRIBE("SUBSCRIBE", true),
    UNSUBSCRIBE("UNSUBSCRIBE", true),
    LIST("LIST", true),
    LSUB("LSUB", true),
    STATUS("STATUS", true),
    APPEND("APPEND", true),
    
    // Selected State
    CHECK("CHECK", true, true),
    CLOSE("CLOSE", true, true),
    EXPUNGE("EXPUNGE", true, true),
    SEARCH("SEARCH", true, true),
    FETCH("FETCH", true, true),
    STORE("STORE", true, true),
    COPY("COPY", true, true),
    UID("UID", true, true),
    
    // Extensions
    IDLE("IDLE", true, true),
    NAMESPACE("NAMESPACE", true),
    ENABLE("ENABLE", true),
    COMPRESS("COMPRESS", true),
    SORT("SORT", true, true),
    THREAD("THREAD", true, true),
    ID("ID", false)
}

