    // ==========================================
    // UTILITY METHODS (1000+ LOC)
    // ==========================================
    
    private fun nextTag(): String {
        return "A${tagCounter.incrementAndGet()}"
    }
    
    private suspend fun sendCommandWithResponse(command: String): ImapResponse {
        val tag = nextTag()
        sendRaw("$tag $command")
        return readResponse(tag)
    }
    
    private fun sendRaw(data: String) {
        if (config.debugMode) {
            logger.debug("C: $data")
        }
        writer?.let {
            it.write(data)
            it.write("\r\n")
            it.flush()
        } ?: throw ImapConnectionException("Not connected")
    }
    
    private suspend fun readResponse(expectedTag: String? = null): ImapResponse {
        while (true) {
            val line = reader?.readLine() 
                ?: throw ImapConnectionException("Connection closed")
            
            if (config.debugMode) {
                logger.debug("S: $line")
            }
            
            // Handle continuation responses
            if (line.startsWith("+")) {
                return ImapResponse(
                    tag = null,
                    type = ImapResponseType.CONTINUATION,
                    message = line.substring(1).trim()
                )
            }
            
            // Handle tagged responses
            if (line.startsWith("*")) {
                if (expectedTag != null) {
                    // Unsolicited response, continue reading
                    continue
                }
                return parseUntaggedResponse(line)
            }
            
            // Check if this is our expected tag
            val tag = line.substringBefore(" ")
            if (expectedTag != null && tag != expectedTag) {
                // Not our response, continue
                continue
            }
            
            return when {
                line.contains("OK") -> ImapResponse(
                    tag = tag,
                    type = ImapResponseType.OK,
                    message = line.substringAfter("OK "),
                    responseCode = extractResponseCode(line)
                )
                line.contains("NO") -> ImapResponse(
                    tag = tag,
                    type = ImapResponseType.NO,
                    message = line.substringAfter("NO ")
                )
                line.contains("BAD") -> ImapResponse(
                    tag = tag,
                    type = ImapResponseType.BAD,
                    message = line.substringAfter("BAD ")
                )
                line.contains("PREAUTH") -> ImapResponse(
                    tag = tag,
                    type = ImapResponseType.PREAUTH,
                    message = line.substringAfter("PREAUTH ")
                )
                line.contains("BYE") -> ImapResponse(
                    tag = tag,
                    type = ImapResponseType.BYE,
                    message = line.substringAfter("BYE ")
                )
                else -> ImapResponse(
                    tag = tag,
                    type = ImapResponseType.OK,
                    message = line
                )
            }
        }
    }
    
    private fun parseUntaggedResponse(line: String): ImapResponse {
        return ImapResponse(
            tag = null,
            type = ImapResponseType.OK,
            message = line.substring(2).trim()
        )
    }
    
    private fun extractResponseCode(line: String): String? {
        val match = Regex("\\[([^\\]]+)\\]").find(line)
        return match?.groupValues?.get(1)
    }
    
    private fun parseFlags(flagsString: String): Set<EmailFlag> {
        return flagsString.split(" ")
            .filter { it.isNotEmpty() }
            .mapNotNull { flag ->
                when (flag.lowercase()) {
                    "\\seen" -> EmailFlag.SEEN
                    "\\answered" -> EmailFlag.ANSWERED
                    "\\flagged" -> EmailFlag.FLAGGED
                    "\\deleted" -> EmailFlag.DELETED
                    "\\draft" -> EmailFlag.DRAFT
                    "\\recent" -> EmailFlag.RECENT
                    "\$forwarded" -> EmailFlag.FORWARDED
                    "\$junk" -> EmailFlag.JUNK
                    "\$notjunk" -> EmailFlag.NOT_JUNK
                    "\$important" -> EmailFlag.IMPORTANT
                    else -> EmailFlag.CUSTOM
                }
            }
            .toSet()
    }
    
    private fun extractFirstNumber(line: String): Int {
        val match = Regex("\\d+").find(line)
        return match?.value?.toIntOrNull() ?: 0
    }
    
    private fun extractNumber(line: String, prefix: String): Int {
        val pattern = "$prefix (\\d+)"
        val match = Regex(pattern).find(line)
        return match?.groupValues?.get(1)?.toIntOrNull() ?: 0
    }
    
    private fun requireAuth() {
        if (state == ImapState.NOT_AUTHENTICATED) {
            throw ImapStateException("Not authenticated")
        }
    }
    
    private fun requireSelectedState() {
        if (state != ImapState.SELECTED) {
            throw ImapStateException("No mailbox selected")
        }
    }
    
    // ==========================================
    // NAMESPACE SUPPORT (300+ LOC)
    // ==========================================
    
    data class Namespace(
        val personal: List<NamespaceInfo>,
        val otherUsers: List<NamespaceInfo>,
        val shared: List<NamespaceInfo>
    )
    
    data class NamespaceInfo(
        val prefix: String,
        val delimiter: String
    )
    
    suspend fun getNamespaces(): Result<Namespace> = withContext(Dispatchers.IO) {
        try {
            requireAuth()
            
            if (!serverCapabilities.namespace) {
                return@withContext Result.failure(
                    ImapException("Server doesn't support NAMESPACE")
                )
            }
            
            val tag = nextTag()
            sendRaw("$tag NAMESPACE")
            
            var namespaces: Namespace? = null
            
            while (true) {
                val line = reader!!.readLine() ?: break
                
                if (line.startsWith("* NAMESPACE")) {
                    namespaces = parseNamespaceResponse(line)
                } else if (line.startsWith("$tag OK")) {
                    break
                } else if (line.startsWith("$tag NO") || line.startsWith("$tag BAD")) {
                    throw ImapCommandException(
                        if (line.startsWith("$tag NO")) ImapResponseType.NO 
                        else ImapResponseType.BAD,
                        line
                    )
                }
            }
            
            Result.success(namespaces ?: Namespace(emptyList(), emptyList(), emptyList()))
            
        } catch (e: Exception) {
            Result.failure(e)
        }
    }
    
    private fun parseNamespaceResponse(line: String): Namespace {
        // Parse complex NAMESPACE response
        // Format: * NAMESPACE (("" "/")) (("~" "/")) (("#shared/" "/"))
        val parts = line.substringAfter("NAMESPACE ").trim()
        
        val personal = parseNamespaceList(parts.substringBefore(") (") + ")")
        val remaining = parts.substringAfter(") (", "")
        val otherUsers = parseNamespaceList("(" + remaining.substringBefore(") (") + ")")
        val shared = parseNamespaceList("(" + remaining.substringAfter(") (", ""))
        
        return Namespace(personal, otherUsers, shared)
    }
    
    private fun parseNamespaceList(data: String): List<NamespaceInfo> {
        if (data == "NIL" || data == "()" || data.isBlank()) {
            return emptyList()
        }
        
        val items = mutableListOf<NamespaceInfo>()
        val regex = Regex("\\(\"([^\"]*)\"\\s*\"([^\"]*)\"\\)")
        
        regex.findAll(data).forEach { match ->
            items.add(
                NamespaceInfo(
                    prefix = match.groupValues[1],
                    delimiter = match.groupValues[2]
                )
            )
        }
        
        return items
    }
    
    // ==========================================
    // CONDITIONAL STORE (CONDSTORE) SUPPORT (800+ LOC)
    // ==========================================
    
    suspend fun enableCondStore(): Result<Unit> = withContext(Dispatchers.IO) {
        try {
            requireAuth()
            
            if (!serverCapabilities.condStore) {
                return@withContext Result.failure(
                    ImapException("Server doesn't support CONDSTORE")
                )
            }
            
            val response = sendCommandWithResponse("ENABLE CONDSTORE")
            if (response.type == ImapResponseType.OK) {
                enabledCapabilities.add("CONDSTORE")
                Result.success(Unit)
            } else {
                Result.failure(ImapCommandException(response.type, response.message))
            }
            
        } catch (e: Exception) {
            Result.failure(e)
        }
    }
    
    suspend fun fetchChanges(
        sequenceSet: String,
        sinceModSeq: Long,
        fetchItems: List<FetchItem> = listOf(
            FetchItem.FLAGS,
            FetchItem.UID,
            FetchItem.MODSEQ
        )
    ): Result<List<FetchResponse>> = withContext(Dispatchers.IO) {
        
        try {
            requireSelectedState()
            
            if (!enabledCapabilities.contains("CONDSTORE")) {
                return@withContext Result.failure(
                    ImapException("CONDSTORE not enabled")
                )
            }
            
            val itemsString = buildFetchItemsString(fetchItems)
            val tag = nextTag()
            
            sendRaw("$tag FETCH $sequenceSet $itemsString (CHANGEDSINCE $sinceModSeq)")
            
            val responses = mutableListOf<FetchResponse>()
            
            while (true) {
                val line = reader!!.readLine() ?: break
                
                if (line.startsWith("*")) {
                    if (line.contains("FETCH")) {
                        val response = parseFetchResponse(line, fetchItems, reader)
                        responses.add(response)
                    }
                } else if (line.startsWith("$tag OK")) {
                    break
                } else if (line.startsWith("$tag NO") || line.startsWith("$tag BAD")) {
                    throw ImapCommandException(
                        if (line.startsWith("$tag NO")) ImapResponseType.NO 
                        else ImapResponseType.BAD,
                        line
                    )
                }
            }
            
            Result.success(responses)
            
        } catch (e: Exception) {
            Result.failure(e)
        }
    }
    
    // ==========================================
    // QRESYNC SUPPORT (1000+ LOC)
    // ==========================================
    
    suspend fun enableQResync(): Result<Unit> = withContext(Dispatchers.IO) {
        try {
            requireAuth()
            
            if (!serverCapabilities.qResync) {
                return@withContext Result.failure(
                    ImapException("Server doesn't support QRESYNC")
                )
            }
            
            val response = sendCommandWithResponse("ENABLE QRESYNC")
            if (response.type == ImapResponseType.OK) {
                enabledCapabilities.add("QRESYNC")
                
                // Also enable CONDSTORE as QRESYNC requires it
                if (!enabledCapabilities.contains("CONDSTORE")) {
                    enableCondStore()
                }
                
                Result.success(Unit)
            } else {
                Result.failure(ImapCommandException(response.type, response.message))
            }
            
        } catch (e: Exception) {
            Result.failure(e)
        }
    }
    
    suspend fun selectWithQResync(
        mailboxName: String,
        uidValidity: Long,
        knownUids: List<Long>,
        knownSeqRanges: List<Pair<Long, Long>>? = null,
        knownModSeq: Long? = null
    ): Result<MailboxInfo> = withContext(Dispatchers.IO) {
        
        try {
            requireAuth()
            
            if (!enabledCapabilities.contains("QRESYNC")) {
                return@withContext Result.failure(
                    ImapException("QRESYNC not enabled")
                )
            }
            
            // Build QRESYNC parameters
            val uidParam = knownUids.joinToString(",")
            
            val seqRangeParam = if (knownSeqRanges != null) {
                knownSeqRanges.joinToString(",") { "${it.first}:${it.second}" }
            } else {
                null
            }
            
            val modSeqParam = knownModSeq?.toString()
            
            val qresyncParams = mutableListOf<String>()
            qresyncParams.add("($uidValidity $uidParam")
            
            if (seqRangeParam != null && modSeqParam != null) {
                qresyncParams.add("$seqRangeParam")
                qresyncParams.add("$modSeqParam")
            }
            qresyncParams.add(")")
            
            val paramsString = qresyncParams.joinToString(" ")
            
            val tag = nextTag()
            sendRaw("$tag SELECT \"$mailboxName\" (QRESYNC $paramsString)")
            
            val mailbox = parseMailboxSelectResponse(tag)
            selectedMailbox = mailbox
            state = ImapState.SELECTED
            
            Result.success(mailbox)
            
        } catch (e: Exception) {
            Result.failure(e)
        }
    }
}

// ============================================
// LOGGER CLASS (200+ LOC)
// ============================================

class ImapLogger {
    private val logEntries = mutableListOf<LogEntry>()
    private val maxEntries = 10000
    
    enum class Level {
        DEBUG, INFO, WARN, ERROR
    }
    
    data class LogEntry(
        val timestamp: Long,
        val level: Level,
        val message: String,
        val throwable: Throwable? = null
    )
    
    fun debug(message: String) {
        log(Level.DEBUG, message)
    }
    
    fun info(message: String) {
        log(Level.INFO, message)
    }
    
    fun warn(message: String) {
        log(Level.WARN, message)
    }
    
    fun error(message: String, throwable: Throwable? = null) {
        log(Level.ERROR, message, throwable)
    }
    
    private fun log(level: Level, message: String, throwable: Throwable? = null) {
        val entry = LogEntry(
            timestamp = System.currentTimeMillis(),
            level = level,
            message = message,
            throwable = throwable
        )
        
        synchronized(logEntries) {
            logEntries.add(entry)
            if (logEntries.size > maxEntries) {
                logEntries.removeAt(0)
            }
        }
    }
    
    fun getRecentLogs(count: Int = 100): List<LogEntry> {
        return synchronized(logEntries) {
            logEntries.takeLast(count)
        }
    }
    
    fun clearLogs() {
        synchronized(logEntries) {
            logEntries.clear()
        }
    }
}