    suspend fun moveMessages(
        sequenceSet: String,
        destinationMailbox: String,
        useUid: Boolean = false
    ): Result<Unit> = withContext(Dispatchers.IO) {
        
        try {
            requireSelectedState()
            
            if (serverCapabilities.move) {
                // Use MOVE extension if available
                val uidPrefix = if (useUid) "UID " else ""
                val response = sendCommandWithResponse(
                    "${uidPrefix}MOVE $sequenceSet \"$destinationMailbox\""
                )
                
                if (response.type == ImapResponseType.OK) {
                    Result.success(Unit)
                } else {
                    Result.failure(ImapCommandException(response.type, response.message))
                }
            } else {
                // Fallback: Copy + Delete + Expunge
                val copyResult = copyMessages(sequenceSet, destinationMailbox, useUid)
                if (copyResult.isFailure) return copyResult
                
                val deleteResult = storeFlags(
                    sequenceSet,
                    setOf(EmailFlag.DELETED),
                    StoreOperation.ADD,
                    useUid
                )
                if (deleteResult.isFailure) return deleteResult
                
                val expungeResult = expunge()
                if (expungeResult.isFailure) return expungeResult
                
                Result.success(Unit)
            }
            
        } catch (e: Exception) {
            Result.failure(e)
        }
    }
    
    suspend fun expunge(): Result<List<Long>> = withContext(Dispatchers.IO) {
        try {
            requireSelectedState()
            
            val tag = nextTag()
            sendRaw("$tag EXPUNGE")
            
            val expungedSeqs = mutableListOf<Long>()
            
            while (true) {
                val line = reader!!.readLine() ?: break
                
                if (line.contains("EXPUNGE")) {
                    val seqMatch = Regex("\\* (\\d+) EXPUNGE").find(line)
                    seqMatch?.groupValues?.get(1)?.toLongOrNull()?.let {
                        expungedSeqs.add(it)
                    }
                } else if (line.startsWith("$tag")) {
                    if (line.contains("OK")) {
                        break
                    } else {
                        throw ImapCommandException(
                            if (line.contains("NO")) ImapResponseType.NO 
                            else ImapResponseType.BAD,
                            line
                        )
                    }
                }
            }
            
            Result.success(expungedSeqs)
            
        } catch (e: Exception) {
            Result.failure(e)
        }
    }
    
