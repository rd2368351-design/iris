    private fun buildFlagsString(flags: Set<EmailFlag>): String {
        val flagStrings = flags.map { flag ->
            when (flag) {
                EmailFlag.SEEN -> "\\Seen"
                EmailFlag.ANSWERED -> "\\Answered"
                EmailFlag.FLAGGED -> "\\Flagged"
                EmailFlag.DELETED -> "\\Deleted"
                EmailFlag.DRAFT -> "\\Draft"
