    suspend fun threadMessages(
        algorithm: ThreadAlgorithm = ThreadAlgorithm.REFERENCES,
        searchCriteria: SearchCriteria? = null,
        useUid: Boolean = false,
        charset: String = "UTF-8"
    ): Result<List<List<Long>>> = withContext(Dispatchers.IO) {
        
        try {
            requireSelectedState()
            
            if (!serverCapabilities.thread) {
                return@withContext Result.failure(
                    ImapException("Server doesn't support THREAD")
                )
            }
            
            val algorithmString = when (algorithm) {
                ThreadAlgorithm.ORDEREDSUBJECT -> "ORDEREDSUBJECT"
                ThreadAlgorithm.REFERENCES -> "REFERENCES"
                ThreadAlgorithm.REFS -> "REFS"
            }
            
            val uidPrefix = if (useUid) "UID " else ""
            val searchString = searchCriteria?.let { buildSearchString(it, charset) } ?: "ALL"
            
            val tag = nextTag()
            sendRaw("$tag ${uidPrefix}THREAD $algorithmString $charset $searchString")
            
            val threads = mutableListOf<List<Long>>()
            
            while (true) {
                val line = reader!!.readLine() ?: break
                
                if (line.startsWith("* THREAD")) {
                    val threadData = line.substringAfter("* THREAD").trim()
                    val parsedThreads = parseThreadResponse(threadData)
                    threads.addAll(parsedThreads)
                } else if (line.startsWith("$tag")) {
                    if (line.contains("OK")) break
                    else throw ImapCommandException(
                        if (line.contains("NO")) ImapResponseType.NO 
                        else ImapResponseType.BAD,
                        line
                    )
                }
            }
            
            Result.success(threads)
            
        } catch (e: Exception) {
            Result.failure(e)
        }
    }
    
    enum class ThreadAlgorithm {
        ORDEREDSUBJECT, REFERENCES, REFS
    }
    
    private fun parseThreadResponse(data: String): List<List<Long>> {
        // Parse nested parentheses structure for thread tree
        val threads = mutableListOf<List<Long>>()
        val stack = mutableListOf<MutableList<Long>>()
        var currentThread = mutableListOf<Long>()
        
        val tokens = data.replace("(", " ( ").replace(")", " ) ").split(" ")
        
        for (token in tokens) {
            when {
                token == "(" -> {
                    stack.add(currentThread)
                    currentThread = mutableListOf()
                }
                token == ")" -> {
                    if (currentThread.isNotEmpty()) {
                        threads.add(currentThread)
                    }
                    currentThread = if (stack.isNotEmpty()) stack.removeAt(stack.lastIndex) 
                                   else mutableListOf()
                }
                token.toLongOrNull() != null -> {
                    currentThread.add(token.toLong())
                }
            }
        }
        
        return threads
    }
    
