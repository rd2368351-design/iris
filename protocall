    suspend fun appendMessage(
        mailboxName: String,
        message: ByteArray,
        flags: Set<EmailFlag> = emptySet(),
        dateTime: String? = null
    ): Result<Long> = withContext(Dispatchers.IO) {
        
        try {
            requireAuth()
            
            val flagsString = if (flags.isNotEmpty()) {
                " (${buildFlagsString(flags)})"
            } else ""
            
            val dateString = if (dateTime != null) " \"$dateTime\"" else ""
            val messageSize = message.size
            
            val tag = nextTag()
            sendRaw(
                "$tag APPEND \"$mailboxName\"$flagsString$dateString {$messageSize}"
            )
            
            // Wait for continuation request
            val continuationResponse = readResponse()
            if (continuationResponse.type != ImapResponseType.CONTINUATION) {
                throw ImapException("Expected continuation, got: ${continuationResponse.type}")
            }
            
            // Send message data
            outputStream!!.write(message)
            outputStream!!.flush()
            sendRaw("") // End of message marker
            
            // Parse response for UID
            val response = readResponse()
            if (response.type == ImapResponseType.OK) {
                val uid = response.responseCode?.let { code ->
                    if (code.startsWith("APPENDUID")) {
                        val parts = code.split(" ")
                        parts.last().toLongOrNull()
                    } else null
                }
                Result.success(uid ?: 0L)
            } else {
                Result.failure(ImapCommandException(response.type, response.message))
            }
            
        } catch (e: Exception) {
            Result.failure(e)
        }
    }
    
